---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-logo">
			<span class="logo-eyebrow">Portal de conocimiento</span>
			<span class="logo-title">Regresión a Vidas Pasadas</span>
		</a>
		<div class="nav-links" id="nav-links">
			<HeaderLink href="/">Inicio</HeaderLink>
			<HeaderLink href="/blog">Artículos</HeaderLink>
			<HeaderLink href="/expositores">Expositores</HeaderLink>
			<HeaderLink href="/srt">SRT</HeaderLink>
			<HeaderLink href="/hipnosis">Hipnosis</HeaderLink>
			<HeaderLink href="/libros">Libros</HeaderLink>
			<HeaderLink href="/peliculas">Películas</HeaderLink>
		</div>
		<div class="nav-actions">
			<button class="search-trigger" aria-label="Buscar" id="search-trigger">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
				</svg>
			</button>
			<button class="hamburger" aria-label="Menú" id="hamburger" aria-expanded="false">
				<span></span>
				<span></span>
				<span></span>
			</button>
		</div>
	</nav>
	<div class="header-line"></div>
</header>

<script>
	const hamburger = document.getElementById('hamburger');
	const navLinks = document.getElementById('nav-links');
	const searchTrigger = document.getElementById('search-trigger');

	hamburger?.addEventListener('click', () => {
		const isOpen = navLinks?.classList.toggle('open');
		hamburger.setAttribute('aria-expanded', String(isOpen));
	});

	// Close nav when a link inside is clicked
	navLinks?.querySelectorAll('a').forEach(link => {
		link.addEventListener('click', () => {
			navLinks.classList.remove('open');
			hamburger?.setAttribute('aria-expanded', 'false');
		});
	});

	searchTrigger?.addEventListener('click', () => {
		const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null;
		dialog?.showModal();
	});
</script>

<style>
	header {
		background: #FDFAF4;
		border-bottom: 1px solid rgba(184, 149, 42, 0.15);
		position: sticky;
		top: 0;
		z-index: 100;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1.5em;
		height: 68px;
	}

	.site-logo {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		line-height: 1.15;
		flex-shrink: 0;
	}

	.logo-eyebrow {
		font-family: 'Cinzel', serif;
		font-size: 0.6em;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: #A89060;
	}

	.logo-title {
		font-family: 'Cinzel', serif;
		font-size: 0.95em;
		font-weight: 500;
		color: #8B6914;
		letter-spacing: 0.04em;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25em;
	}

	.nav-links :global(a) {
		padding: 0.4em 0.85em;
		color: #7A6840;
		font-family: 'Cinzel', serif;
		font-size: 0.75em;
		letter-spacing: 0.06em;
		text-decoration: none;
		border-bottom: 2px solid transparent;
		transition: color 0.2s;
	}

	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		color: #2C1F0E;
		border-bottom-color: #B8952A;
		text-decoration: none;
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}

	.search-trigger,
	.hamburger {
		background: none;
		border: none;
		cursor: pointer;
		color: #7A6840;
		padding: 0.4em;
		border-radius: 4px;
		transition: color 0.2s, background 0.2s;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.search-trigger:hover,
	.hamburger:hover {
		color: #2C1F0E;
		background: rgba(184, 149, 42, 0.08);
	}

	.hamburger {
		display: none;
		flex-direction: column;
		gap: 4px;
		width: 36px;
		height: 36px;
	}

	.hamburger span {
		display: block;
		width: 20px;
		height: 1.5px;
		background: currentColor;
		border-radius: 2px;
		transition: transform 0.22s, opacity 0.22s;
		transform-origin: center;
	}

	.hamburger[aria-expanded="true"] span:nth-child(1) {
		transform: translateY(5.5px) rotate(45deg);
	}
	.hamburger[aria-expanded="true"] span:nth-child(2) {
		opacity: 0;
	}
	.hamburger[aria-expanded="true"] span:nth-child(3) {
		transform: translateY(-5.5px) rotate(-45deg);
	}

	.header-line {
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(184,149,42,0.3) 30%, rgba(184,149,42,0.3) 70%, transparent);
	}

	@media (max-width: 768px) {
		.hamburger {
			display: flex;
		}

		.nav-links {
			position: fixed;
			top: 69px;
			left: 0;
			right: 0;
			bottom: 0;
			background: #FDFAF4;
			flex-direction: column;
			align-items: stretch;
			gap: 0;
			padding: 1em 0;
			transform: translateX(-100%);
			transition: transform 0.25s ease;
			border-right: 1px solid rgba(184, 149, 42, 0.15);
			overflow-y: auto;
			width: 72%;
			max-width: 280px;
			box-shadow: 4px 0 20px rgba(44, 31, 14, 0.08);
		}

		.nav-links.open {
			transform: translateX(0);
		}

		.nav-links :global(a) {
			padding: 0.9em 1.75em;
			font-size: 0.85em;
			border-bottom: 1px solid rgba(184, 149, 42, 0.08);
			border-right: none;
		}

		.nav-links :global(a:hover),
		.nav-links :global(a.active) {
			background: rgba(184, 149, 42, 0.06);
			border-bottom-color: rgba(184, 149, 42, 0.08);
		}

		.logo-eyebrow { display: none; }
	}
</style>
