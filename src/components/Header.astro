---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="site-logo">
			<span class="logo-eyebrow">Portal de conocimiento</span>
			<span class="logo-title">Regresión a Vidas Pasadas</span>
		</a>
		<div class="nav-links">
			<HeaderLink href="/">Inicio</HeaderLink>
			<HeaderLink href="/blog">Artículos</HeaderLink>
			<a href="https://www.juanpabloloaiza.com/agenda" target="_blank" rel="noopener" class="nav-cta">
				Agenda una sesión
			</a>
		</div>
	</nav>
	<div class="header-line"></div>
</header>

<style>
	header {
		background: #FDFAF4;
		border-bottom: 1px solid rgba(184, 149, 42, 0.15);
		position: sticky;
		top: 0;
		z-index: 100;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1.5em;
		height: 68px;
	}

	.site-logo {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		line-height: 1.15;
	}

	.logo-eyebrow {
		font-family: 'Cinzel', serif;
		font-size: 0.6em;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: #A89060;
	}

	.logo-title {
		font-family: 'Cinzel', serif;
		font-size: 0.95em;
		font-weight: 500;
		color: #8B6914;
		letter-spacing: 0.04em;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25em;
	}

	.nav-links :global(a) {
		padding: 0.4em 0.85em;
		color: #7A6840;
		font-family: 'Cinzel', serif;
		font-size: 0.75em;
		letter-spacing: 0.06em;
		text-decoration: none;
		border-bottom: 2px solid transparent;
		transition: color 0.2s;
	}

	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		color: #2C1F0E;
		border-bottom-color: #B8952A;
		text-decoration: none;
	}

	.nav-cta {
		margin-left: 0.75em;
		padding: 0.5em 1.25em !important;
		background: #B8952A !important;
		color: #fff !important;
		border-radius: 4px;
		font-weight: 500 !important;
		border-bottom: none !important;
		letter-spacing: 0.06em;
		transition: background 0.2s !important;
	}

	.nav-cta:hover {
		background: #8B6914 !important;
		color: #fff !important;
	}

	.header-line {
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(184,149,42,0.3) 30%, rgba(184,149,42,0.3) 70%, transparent);
	}

	@media (max-width: 600px) {
		.nav-links :global(a:not(.nav-cta)) { display: none; }
		.logo-eyebrow { display: none; }
	}
</style>
