---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-logo">REGRESIÓN A VIDAS PASADAS</div>

		<nav class="footer-links">
			<a href="/blog">Artículos</a>
			<a href="/expositores">Expositores</a>
			<a href="/srt">SRT</a>
			<a href="/hipnosis">Hipnosis</a>
			<a href="/libros">Libros</a>
			<a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener" class="footer-link-highlight">juanpabloloaiza.com</a>
		</nav>

		<p class="footer-desc">
			Portal de conocimiento independiente para la exploración de la consciencia transpersonal.
			Investigación en regresión a vidas pasadas, hipnosis clínica y liberación espiritual.
		</p>

		<p class="footer-copy">© {today.getFullYear()} Regresión a Vidas Pasadas. Portal de conocimiento espiritual independiente.</p>
	</div>
</footer>

<style>
	footer {
		background: #F5EFE0;
		border-top: 1px solid rgba(184, 149, 42, 0.3);
		opacity: 0.95;
		transition: opacity 0.3s;
	}

	footer:hover { opacity: 1; }

	.footer-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5em;
		padding: 3.5em 2em;
		text-align: center;
		max-width: 1200px;
		margin: 0 auto;
	}

	.footer-logo {
		font-family: 'Playfair Display', serif;
		font-size: 1em;
		font-weight: 700;
		color: #B8952A;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.5em 2em;
	}

	.footer-links a {
		font-family: 'EB Garamond', serif;
		font-size: 0.9em;
		color: #7A6840;
		text-decoration: none;
		transition: color 0.2s;
	}

	.footer-links a:hover { color: #2C1F0E; text-decoration: none; }

	.footer-link-highlight {
		color: #B8952A !important;
		text-decoration: underline !important;
	}
	.footer-link-highlight:hover { color: #8B6914 !important; }

	.footer-desc {
		font-family: 'EB Garamond', serif;
		font-size: 0.78em;
		color: #7A6840;
		line-height: 1.65;
		max-width: 540px;
		margin: 0;
		opacity: 0.7;
	}

	.footer-copy {
		font-family: 'EB Garamond', serif;
		font-size: 0.75em;
		color: #2C1F0E;
		opacity: 0.6;
		margin: 0;
	}
</style>
