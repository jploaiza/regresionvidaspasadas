---
const today = new Date();
---

<footer>
	<div class="footer-ornament">✦</div>
	<div class="footer-author">
		<p>Portal de conocimiento sobre regresión a vidas pasadas, hipnosis y liberación espiritual.</p>
	</div>
	<div class="footer-bottom">
		<div class="footer-links">
			<a href="/">Inicio</a>
			<span>·</span>
			<a href="/blog">Artículos</a>
			<span>·</span>
			<a href="/libros">Libros</a>
			<span>·</span>
			<a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener">juanpabloloaiza.com</a>
		</div>
		<p class="footer-copy">© {today.getFullYear()} regresionvidaspasadas.com</p>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid rgba(184, 149, 42, 0.15);
		margin-top: 4em;
	}

	.footer-ornament {
		text-align: center;
		color: #D4AF6A;
		font-size: 1.2em;
		padding: 1.5em 0 0;
		letter-spacing: 0.5em;
	}

	.footer-author {
		text-align: center;
		padding: 1.25em 1.5em 0.5em;
		font-size: 0.83em;
		color: #A89060;
	}

	.footer-author a {
		color: #8B6914;
		text-decoration: none;
	}

	.footer-author a:hover {
		text-decoration: underline;
	}

	.footer-bottom {
		background: #FDFAF4;
		padding: 1.5em 1.5em 2.5em;
		text-align: center;
		color: #A89060;
		font-size: 0.82em;
	}

	.footer-links {
		display: flex;
		justify-content: center;
		gap: 0.75em;
		margin-bottom: 0.5em;
	}

	.footer-links a {
		color: #A89060;
		text-decoration: none;
	}

	.footer-links a:hover { color: #8B6914; }

	.footer-links span { color: #D4C090; }

	.footer-copy { margin: 0; color: #C0A870; }
</style>
