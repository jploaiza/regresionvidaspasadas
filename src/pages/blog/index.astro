---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import SearchModal from '../../components/SearchModal.astro';
import { SITE_TITLE, CATEGORY, FEATURED_SLUG, SLUG_IMG } from '../../consts';

import imgVelasSeance    from '../../assets/blog/srt-velas-seance.jpg';
import imgVelaOscuridad  from '../../assets/blog/srt-vela-oscuridad.jpg';
import imgManosLuz       from '../../assets/blog/srt-manos-luz.jpg';
import imgOjoMistico     from '../../assets/blog/hipnosis-ojo-mistico.jpg';
import imgMeditacion     from '../../assets/blog/rvp-meditacion.jpg';
import imgDefault        from '../../assets/blog/hero-meditacion-amanecer.jpg';
import imgCosmos         from '../../assets/blog/cosmos-estrellas.jpg';
import imgHumoOscuro     from '../../assets/blog/srt-humo-oscuro.jpg';
import imgTerapia        from '../../assets/blog/terapia-sesion.jpg';
import imgPortalLuz      from '../../assets/blog/portal-luz.jpg';
import imgNinos          from '../../assets/blog/ninos-naturaleza.jpg';
import imgMeditGrupal    from '../../assets/blog/meditacion-grupal.jpg';
import imgRitualFuego    from '../../assets/blog/ritual-fuego.jpg';
import imgSilueta        from '../../assets/blog/silueta-espiritual.jpg';
import imgLibros         from '../../assets/blog/libros-vintage.jpg';
import imgQueEs          from '../../assets/blog/que-es-regresion.jpg';
import imgBeneficios     from '../../assets/blog/beneficios-regresion.jpg';
import imgSesion         from '../../assets/blog/sesion-regresion.jpg';
import type { ImageMetadata } from 'astro';

const IMG_REGISTRY: Record<string, ImageMetadata> = {
  'srt-velas-seance':       imgVelasSeance,
  'srt-vela-oscuridad':     imgVelaOscuridad,
  'srt-manos-luz':          imgManosLuz,
  'hipnosis-ojo-mistico':   imgOjoMistico,
  'rvp-meditacion':         imgMeditacion,
  'hero-meditacion-amanecer': imgDefault,
  'cosmos-estrellas':       imgCosmos,
  'srt-humo-oscuro':        imgHumoOscuro,
  'terapia-sesion':         imgTerapia,
  'portal-luz':             imgPortalLuz,
  'ninos-naturaleza':       imgNinos,
  'meditacion-grupal':      imgMeditGrupal,
  'ritual-fuego':           imgRitualFuego,
  'silueta-espiritual':     imgSilueta,
  'libros-vintage':         imgLibros,
  'que-es-regresion':       imgQueEs,
  'beneficios-regresion':   imgBeneficios,
  'sesion-regresion':       imgSesion,
};

const EXPOSITOR_IMG: Record<string, ImageMetadata> = {
  'carl-wickland':   imgVelasSeance,
  'william-baldwin': imgManosLuz,
  'edith-fiore':     imgMeditacion,
  'alan-sanderson':  imgMeditacion,
  'srt':             imgVelaOscuridad,
  'hipnosis':        imgOjoMistico,
};

function getPostImage(id: string, heroImage: ImageMetadata | undefined, expositor?: string): ImageMetadata {
  if (heroImage) return heroImage;
  if (SLUG_IMG[id]) {
    const k = SLUG_IMG[id];
    if (IMG_REGISTRY[k]) return IMG_REGISTRY[k];
  }
  if (expositor && EXPOSITOR_IMG[expositor]) return EXPOSITOR_IMG[expositor];
  return imgDefault;
}

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = allPosts.find(p => p.id === FEATURED_SLUG) ?? allPosts[0];
const gridPosts = allPosts.filter(p => p.id !== featured.id);
const featuredImage = getPostImage(featured.id, featured.data.heroImage, featured.data.expositor);
const featuredCat = featured.data.expositor ? CATEGORY[featured.data.expositor] : undefined;
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`Artículos · ${SITE_TITLE}`} description="Todos los artículos sobre regresión a vidas pasadas, hipnosis clínica y terapia de liberación espiritual." />
	</head>
	<body>
		<Header />
		<SearchModal />
		<main class="page-wrap">
			<div class="page-header">
				<span class="ornament">✦</span>
				<h1>Artículos</h1>
				<p class="page-desc">{allPosts.length} artículos sobre regresión, hipnosis y liberación espiritual.</p>
			</div>

			<!-- Artículo destacado -->
			<a href={`/blog/${featured.id}/`} class="featured-card" aria-label={`Artículo destacado: ${featured.data.title}`}>
				<Image
					src={featuredImage}
					alt={featured.data.title}
					width={1100}
					height={460}
					class="featured-img"
				/>
				<div class="featured-overlay">
					<div class="featured-content">
						<span class="featured-eyebrow">Artículo destacado</span>
						{featuredCat && (
							<span class="featured-badge" style={`background:${featuredCat.color}; color:#fff`}>
								{featuredCat.label}
							</span>
						)}
						<h2 class="featured-title">{featured.data.title}</h2>
						{featured.data.description && (
							<p class="featured-desc">{featured.data.description}</p>
						)}
						<div class="featured-meta">
							<FormattedDate date={featured.data.pubDate} />
							<span class="featured-cta">Leer artículo →</span>
						</div>
					</div>
				</div>
			</a>

			<!-- Filtros -->
			<div class="filter-bar" role="tablist" aria-label="Filtrar por categoría">
				<button class="filter-btn active" data-filter="all" role="tab" aria-selected="true">Todos</button>
				<button class="filter-btn" data-filter="rvp" role="tab" aria-selected="false">Expositores RVP</button>
				<button class="filter-btn" data-filter="srt" role="tab" aria-selected="false">SRT</button>
				<button class="filter-btn" data-filter="hipnosis" role="tab" aria-selected="false">Hipnosis</button>
			</div>

			<!-- Grid paginado -->
			<ul class="posts-grid" id="posts-grid">
				{
					gridPosts.map((post, idx) => {
						const cat = post.data.expositor ? CATEGORY[post.data.expositor] : undefined;
						const thumb = getPostImage(post.id, post.data.heroImage, post.data.expositor);
						const group = cat?.group ?? 'rvp';
						return (
							<li data-cat={group} data-idx={idx}>
								<a href={`/blog/${post.id}/`} class="post-card">
									<div class="card-img">
										<Image src={thumb} alt={post.data.title} width={500} height={280} loading="lazy" />
										{cat && (
											<span class="card-badge" style={`background:${cat.color}; color:#fff`}>
												{cat.label}
											</span>
										)}
									</div>
									<div class="card-body">
										<h2 class="card-title">{post.data.title}</h2>
										<p class="card-excerpt">{post.data.description}</p>
										<span class="card-date"><FormattedDate date={post.data.pubDate} /></span>
									</div>
								</a>
							</li>
						);
					})
				}
			</ul>

			<!-- Paginación -->
			<nav class="pagination" id="pagination" aria-label="Paginación de artículos"></nav>

			<p class="results-count" id="results-count"></p>
		</main>
		<Footer />
	</body>
</html>

<script>
	const PAGE_SIZE = 12;
	let currentPage = 1;
	let currentFilter = 'all';

	const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
	const allItems = Array.from(document.querySelectorAll<HTMLLIElement>('#posts-grid li'));
	const countEl = document.getElementById('results-count');
	const paginationEl = document.getElementById('pagination');

	function getFiltered(): HTMLLIElement[] {
		if (currentFilter === 'all') return allItems;
		return allItems.filter(li => li.dataset.cat === currentFilter);
	}

	function renderPage() {
		const filtered = getFiltered();
		const totalPages = Math.ceil(filtered.length / PAGE_SIZE);
		const start = (currentPage - 1) * PAGE_SIZE;
		const end = start + PAGE_SIZE;
		const visible = new Set(filtered.slice(start, end));

		allItems.forEach(li => {
			li.style.display = visible.has(li) ? '' : 'none';
		});

		if (countEl) {
			countEl.textContent = `Mostrando ${visible.size} de ${filtered.length} artículos`;
		}

		renderPagination(totalPages);
	}

	function renderPagination(totalPages: number) {
		if (!paginationEl) return;
		paginationEl.innerHTML = '';
		if (totalPages <= 1) return;

		const prev = document.createElement('button');
		prev.textContent = '←';
		prev.className = 'page-btn' + (currentPage === 1 ? ' disabled' : '');
		prev.disabled = currentPage === 1;
		prev.addEventListener('click', () => { currentPage--; renderPage(); scrollToGrid(); });
		paginationEl.appendChild(prev);

		for (let i = 1; i <= totalPages; i++) {
			if (totalPages > 7 && i > 2 && i < totalPages - 1 && Math.abs(i - currentPage) > 1) {
				if (i === 3 || i === totalPages - 2) {
					const dots = document.createElement('span');
					dots.textContent = '…';
					dots.className = 'page-dots';
					paginationEl.appendChild(dots);
				}
				continue;
			}
			const btn = document.createElement('button');
			btn.textContent = String(i);
			btn.className = 'page-btn' + (i === currentPage ? ' active' : '');
			btn.addEventListener('click', () => { currentPage = i; renderPage(); scrollToGrid(); });
			paginationEl.appendChild(btn);
		}

		const next = document.createElement('button');
		next.textContent = '→';
		next.className = 'page-btn' + (currentPage === totalPages ? ' disabled' : '');
		next.disabled = currentPage === totalPages;
		next.addEventListener('click', () => { currentPage++; renderPage(); scrollToGrid(); });
		paginationEl.appendChild(next);
	}

	function scrollToGrid() {
		document.querySelector('.filter-bar')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
	}

	buttons.forEach(btn => {
		btn.addEventListener('click', () => {
			currentFilter = btn.dataset.filter ?? 'all';
			currentPage = 1;
			buttons.forEach(b => {
				b.classList.remove('active');
				b.setAttribute('aria-selected', 'false');
			});
			btn.classList.add('active');
			btn.setAttribute('aria-selected', 'true');
			renderPage();
		});
	});

	renderPage();
</script>

<style>
	.page-wrap {
		max-width: 1080px;
		margin: 0 auto;
		padding: 0 1.5em 4em;
	}

	.page-header {
		text-align: center;
		padding: 3em 0 2em;
	}

	.ornament {
		display: block;
		color: #D4AF6A;
		font-size: 0.85em;
		letter-spacing: 0.5em;
		margin-bottom: 0.75em;
	}

	.page-header h1 {
		font-family: 'Cinzel', serif;
		font-size: 2.5em;
		font-weight: 400;
		color: #2C1F0E;
		margin-bottom: 0.4em;
	}

	.page-desc {
		color: #A89060;
		font-size: 0.9em;
		font-family: 'Cinzel', serif;
		letter-spacing: 0.05em;
	}

	/* ——— Featured card ——— */
	.featured-card {
		display: block;
		position: relative;
		width: 100%;
		height: 460px;
		border-radius: 10px;
		overflow: hidden;
		text-decoration: none;
		margin-bottom: 2.5em;
	}

	.featured-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 40%;
		filter: brightness(0.5) saturate(0.8);
		transition: transform 0.4s, filter 0.4s;
		display: block;
	}

	.featured-card:hover .featured-img {
		transform: scale(1.03);
		filter: brightness(0.45) saturate(0.85);
	}

	.featured-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to bottom,
			rgba(20,10,5,0.05) 0%,
			rgba(20,10,5,0.15) 35%,
			rgba(20,10,5,0.75) 65%,
			rgba(20,10,5,0.92) 100%
		);
		display: flex;
		align-items: flex-end;
	}

	.featured-content {
		padding: 0 2.5em 2.5em;
		max-width: 700px;
	}

	.featured-eyebrow {
		display: block;
		font-family: 'Cinzel', serif;
		font-size: 0.6em;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: rgba(212, 175, 106, 0.85);
		margin-bottom: 0.6em;
	}

	.featured-badge {
		display: inline-block;
		font-family: 'Cinzel', serif;
		font-size: 0.62em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 0.25em 0.7em;
		border-radius: 3px;
		margin-bottom: 0.75em;
	}

	.featured-title {
		font-family: 'Crimson Text', serif;
		font-size: 2.4em;
		font-weight: 400;
		color: #FDFAF4;
		line-height: 1.15;
		margin-bottom: 0.5em;
		text-shadow: 0 2px 10px rgba(0,0,0,0.35);
	}

	.featured-desc {
		font-family: 'Crimson Text', serif;
		font-size: 1.05em;
		color: rgba(253,250,244,0.75);
		line-height: 1.55;
		margin-bottom: 1em;
		font-style: italic;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.featured-meta {
		display: flex;
		align-items: center;
		gap: 1.5em;
		font-family: 'Cinzel', serif;
		font-size: 0.65em;
		letter-spacing: 0.1em;
		color: rgba(255,255,255,0.55);
	}

	.featured-cta {
		color: #D4AF6A;
		font-size: 1.05em;
	}

	/* ——— Filters ——— */
	.filter-bar {
		display: flex;
		gap: 0.5em;
		margin-bottom: 2em;
		flex-wrap: wrap;
	}

	.filter-btn {
		font-family: 'Cinzel', serif;
		font-size: 0.7em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 0.5em 1.1em;
		border: 1px solid rgba(184, 149, 42, 0.3);
		border-radius: 20px;
		background: transparent;
		color: #7A6840;
		cursor: pointer;
		transition: all 0.2s;
	}

	.filter-btn:hover {
		border-color: #B8952A;
		color: #2C1F0E;
		background: rgba(184, 149, 42, 0.06);
	}

	.filter-btn.active {
		background: #B8952A;
		border-color: #B8952A;
		color: #FDFAF4;
	}

	/* ——— Grid: 2 columnas ——— */
	.posts-grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.75em;
	}

	.post-card {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		border-radius: 8px;
		overflow: hidden;
		background: #F5EFE0;
		border: 1px solid rgba(184, 149, 42, 0.1);
		transition: transform 0.2s, box-shadow 0.2s;
		height: 100%;
	}

	.post-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 24px rgba(44, 31, 14, 0.1);
	}

	.card-img {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 9;
		overflow: hidden;
	}

	.card-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: sepia(10%) saturate(0.9);
		transition: transform 0.3s, filter 0.3s;
	}

	.post-card:hover .card-img img {
		transform: scale(1.04);
		filter: sepia(4%) saturate(1.05);
	}

	.card-badge {
		position: absolute;
		bottom: 0.6em;
		left: 0.6em;
		font-family: 'Cinzel', serif;
		font-size: 0.6em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 0.25em 0.6em;
		border-radius: 3px;
	}

	.card-body {
		padding: 1.1em 1.25em 1.25em;
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	.card-title {
		font-family: 'Cinzel', serif;
		font-size: 0.9em;
		font-weight: 400;
		color: #2C1F0E;
		line-height: 1.35;
		margin-bottom: 0.5em;
		transition: color 0.2s;
	}

	.post-card:hover .card-title {
		color: #8B6914;
	}

	.card-excerpt {
		font-size: 0.85em;
		color: #7A6840;
		line-height: 1.55;
		flex: 1;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
		margin-bottom: 0.75em;
	}

	.card-date {
		font-family: 'Cinzel', serif;
		font-size: 0.65em;
		letter-spacing: 0.08em;
		color: #A89060;
		margin-top: auto;
	}

	/* ——— Pagination ——— */
	.pagination {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0.35em;
		margin-top: 3em;
		flex-wrap: wrap;
	}

	:global(.page-btn) {
		font-family: 'Cinzel', serif;
		font-size: 0.72em;
		letter-spacing: 0.08em;
		min-width: 2.4em;
		height: 2.4em;
		padding: 0 0.5em;
		border: 1px solid rgba(184,149,42,0.3);
		border-radius: 4px;
		background: transparent;
		color: #7A6840;
		cursor: pointer;
		transition: all 0.18s;
	}

	:global(.page-btn:hover:not(.disabled)) {
		border-color: #B8952A;
		color: #2C1F0E;
		background: rgba(184,149,42,0.07);
	}

	:global(.page-btn.active) {
		background: #B8952A;
		border-color: #B8952A;
		color: #FDFAF4;
	}

	:global(.page-btn.disabled) {
		opacity: 0.35;
		cursor: default;
	}

	:global(.page-dots) {
		font-family: 'Cinzel', serif;
		font-size: 0.72em;
		color: #A89060;
		padding: 0 0.2em;
	}

	.results-count {
		font-family: 'Cinzel', serif;
		font-size: 0.7em;
		letter-spacing: 0.1em;
		color: #A89060;
		text-align: center;
		margin-top: 1.5em;
	}

	@media (max-width: 700px) {
		.featured-card { height: 320px; }
		.featured-title { font-size: 1.7em; }
		.featured-desc { display: none; }
		.featured-content { padding: 0 1.25em 1.5em; }
		.posts-grid { grid-template-columns: 1fr; }
		.page-header h1 { font-size: 1.8em; }
	}
</style>
