---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import SearchModal from '../components/SearchModal.astro';
import { SITE_DESCRIPTION, SITE_TITLE, CATEGORY } from '../consts';
import heroImg from '../assets/blog/hero-meditacion-amanecer.jpg';

// Default images per category (same as BlogPost.astro)
import imgVelasSeance from '../assets/blog/srt-velas-seance.jpg';
import imgVelaOscuridad from '../assets/blog/srt-vela-oscuridad.jpg';
import imgManosLuz from '../assets/blog/srt-manos-luz.jpg';
import imgOjoMistico from '../assets/blog/hipnosis-ojo-mistico.jpg';
import imgMeditacion from '../assets/blog/rvp-meditacion.jpg';
import imgDefault from '../assets/blog/hero-meditacion-amanecer.jpg';
import type { ImageMetadata } from 'astro';

const IMG_MAP: Record<string, ImageMetadata> = {
  'carl-wickland': imgVelasSeance,
  'william-baldwin': imgManosLuz,
  'edith-fiore': imgMeditacion,
  'alan-sanderson': imgMeditacion,
  'srt': imgVelaOscuridad,
  'hipnosis': imgOjoMistico,
};

function getPostImage(expositor?: string): ImageMetadata {
  return (expositor && IMG_MAP[expositor]) ?? imgDefault;
}

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 16);

const SECTIONS = [
  {
    href: '/expositores',
    titulo: 'Expositores',
    desc: 'Los investigadores que lo documentaron',
    icon: '◈',
    color: '#B8952A',
  },
  {
    href: '/srt',
    titulo: 'SRT',
    desc: 'Liberación espiritual y entidades',
    icon: '◉',
    color: '#8B3A3A',
  },
  {
    href: '/hipnosis',
    titulo: 'Hipnosis',
    desc: 'Historia, mitos y práctica clínica',
    icon: '◎',
    color: '#4A6B8A',
  },
  {
    href: '/libros',
    titulo: 'Libros',
    desc: 'Biblioteca esencial recomendada',
    icon: '▣',
    color: '#5A7A5A',
  },
  {
    href: '/peliculas',
    titulo: 'Películas',
    desc: 'Ficción y documentales para despertar',
    icon: '▶',
    color: '#6A5A7A',
  },
];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<SearchModal />
		<main>
			<div class="hero-image-wrap">
				<Image src={heroImg} alt="Meditación espiritual al amanecer" width={1200} height={480} class="hero-img" />
				<div class="hero-image-overlay"></div>
			</div>
			<section class="hero">
				<div class="hero-ornament">✦ ✦ ✦</div>
				<h1>Regresión a<br />Vidas Pasadas</h1>
				<p class="hero-desc">
					Un portal de conocimiento sobre la terapia de regresión: qué es,
					cómo funciona y qué puedes sanar a través de este proceso profundo.
				</p>
				<div class="hero-divider"></div>
			</section>

			<section class="sections-nav">
				<p class="section-label">Explorar por tema</p>
				<div class="sections-grid">
					{SECTIONS.map(s => (
						<a href={s.href} class="section-card" style={`--accent: ${s.color}`}>
							<span class="section-icon">{s.icon}</span>
							<span class="section-titulo">{s.titulo}</span>
							<span class="section-desc">{s.desc}</span>
						</a>
					))}
				</div>
			</section>

			<section class="posts-section">
				<p class="section-label">Últimos artículos</p>
				<ul class="posts-list">
					{
						posts.map((post) => {
							const cat = post.data.expositor ? CATEGORY[post.data.expositor] : undefined;
							const thumb = post.data.heroImage ?? getPostImage(post.data.expositor);
							return (
								<li>
									<a href={`/blog/${post.id}/`} class="post-link">
										<article class="post-card">
											<div class="post-thumb">
												<Image src={thumb} alt={post.data.title} width={160} height={110} />
											</div>
											<div class="post-body">
												{cat && (
													<span class="post-badge" style={`background:${cat.color}18; color:${cat.color}; border-color:${cat.color}40`}>
														{cat.label}
													</span>
												)}
												<h2 class="post-title">{post.data.title}</h2>
												<p class="post-excerpt">{post.data.description}</p>
												<div class="post-footer">
													<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
													<span class="post-cta">Leer →</span>
												</div>
											</div>
										</article>
									</a>
								</li>
							);
						})
					}
				</ul>
				<div class="ver-todos">
					<a href="/blog" class="ver-todos-link">Ver todos los artículos →</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero-image-wrap {
		position: relative;
		width: 100%;
		height: 420px;
		overflow: hidden;
	}

	.hero-img {
		width: 100%;
		height: 420px;
		object-fit: cover;
		object-position: center 30%;
		border-radius: 0;
		filter: sepia(20%) brightness(0.92) saturate(0.85);
	}

	.hero-image-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(to bottom, rgba(253,250,244,0) 40%, rgba(253,250,244,0.95) 100%);
	}

	.hero {
		text-align: center;
		padding: 2.5em 1em 2em;
	}

	.hero-ornament {
		color: #D4AF6A;
		letter-spacing: 0.6em;
		font-size: 0.7em;
		margin-bottom: 1.25em;
	}

	.hero h1 {
		font-size: 3em;
		font-weight: 400;
		color: #2C1F0E;
		line-height: 1.15;
		margin-bottom: 0.6em;
	}

	.hero-desc {
		max-width: 520px;
		margin: 0 auto 1.75em;
		color: #7A6840;
		font-size: 1.05em;
		line-height: 1.7;
	}

	.hero-divider {
		width: 80px;
		height: 1px;
		background: linear-gradient(90deg, transparent, #D4AF6A, transparent);
		margin: 2.5em auto 0;
	}

	/* ——— Section nav ——— */
	.sections-nav {
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1.5em;
	}

	.section-label {
		font-family: 'Cinzel', serif;
		font-size: 0.7em;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: #A89060;
		margin-bottom: 1.25em;
		margin-top: 3em;
	}

	.sections-grid {
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		gap: 0.75em;
	}

	.section-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 0.35em;
		padding: 1.25em 0.75em;
		background: #F5EFE0;
		border-radius: 8px;
		text-decoration: none;
		border: 1px solid transparent;
		transition: border-color 0.2s, background 0.2s, transform 0.15s;
	}

	.section-card:hover {
		border-color: var(--accent);
		background: #EDE5D0;
		transform: translateY(-2px);
	}

	.section-icon {
		color: var(--accent);
		font-size: 1.4em;
		line-height: 1;
		margin-bottom: 0.1em;
	}

	.section-titulo {
		font-family: 'Cinzel', serif;
		font-size: 0.78em;
		letter-spacing: 0.06em;
		color: #2C1F0E;
		font-weight: 500;
	}

	.section-desc {
		font-size: 0.72em;
		color: #8A7055;
		line-height: 1.4;
	}

	/* ——— Posts list ——— */
	.posts-section {
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1.5em;
	}

	.posts-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.posts-list li {
		border-bottom: 1px solid rgba(184, 149, 42, 0.12);
	}

	.posts-list li:first-child {
		border-top: 1px solid rgba(184, 149, 42, 0.12);
	}

	.post-link {
		display: block;
		text-decoration: none;
	}

	.post-card {
		padding: 1.5em 0;
		display: flex;
		gap: 1.5em;
		align-items: flex-start;
		transition: padding-left 0.2s;
	}

	.post-link:hover .post-card {
		padding-left: 0.4em;
	}

	.post-thumb {
		flex-shrink: 0;
		width: 140px;
		height: 96px;
		border-radius: 6px;
		overflow: hidden;
	}

	.post-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: sepia(12%) saturate(0.9);
		transition: filter 0.3s, transform 0.3s;
	}

	.post-link:hover .post-thumb img {
		filter: sepia(5%) saturate(1.05);
		transform: scale(1.03);
	}

	.post-body {
		flex: 1;
		min-width: 0;
	}

	.post-badge {
		display: inline-block;
		font-family: 'Cinzel', serif;
		font-size: 0.62em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 0.2em 0.6em;
		border-radius: 3px;
		border: 1px solid;
		margin-bottom: 0.5em;
	}

	.post-title {
		font-size: 1.3em;
		font-weight: 400;
		color: #2C1F0E;
		margin-bottom: 0.4em;
		line-height: 1.3;
		transition: color 0.2s;
	}

	.post-link:hover .post-title {
		color: #8B6914;
	}

	.post-excerpt {
		font-size: 0.9em;
		color: #7A6840;
		margin-bottom: 0.6em;
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-footer {
		display: flex;
		align-items: center;
		gap: 1.5em;
	}

	.post-date {
		font-family: 'Cinzel', serif;
		font-size: 0.68em;
		letter-spacing: 0.08em;
		color: #A89060;
	}

	.post-cta {
		font-family: 'Cinzel', serif;
		font-size: 0.7em;
		letter-spacing: 0.06em;
		color: #B8952A;
	}

	.ver-todos {
		text-align: center;
		padding: 2.5em 0 3em;
	}

	.ver-todos-link {
		font-family: 'Cinzel', serif;
		font-size: 0.8em;
		letter-spacing: 0.1em;
		color: #8B6914;
		text-decoration: none;
		border-bottom: 1px solid rgba(184, 149, 42, 0.4);
		padding-bottom: 0.25em;
		transition: color 0.2s, border-color 0.2s;
	}

	.ver-todos-link:hover {
		color: #2C1F0E;
		border-color: #B8952A;
	}

	@media (max-width: 768px) {
		.hero h1 { font-size: 2.2em; }

		.sections-grid {
			grid-template-columns: repeat(3, 1fr);
			overflow-x: auto;
		}

		.post-thumb {
			width: 100px;
			height: 72px;
		}

		.post-title { font-size: 1.1em; }
	}

	@media (max-width: 480px) {
		.sections-grid {
			grid-template-columns: repeat(5, 130px);
			overflow-x: auto;
			padding-bottom: 0.5em;
			scroll-snap-type: x mandatory;
		}

		.section-card {
			scroll-snap-align: start;
		}

		.post-thumb {
			width: 80px;
			height: 60px;
		}
	}
</style>
