---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-ornament">✦ ✦ ✦</div>
				<h1>Regresión a<br />Vidas Pasadas</h1>
				<p class="hero-desc">
					Un portal de conocimiento sobre la terapia de regresión: qué es,
					cómo funciona y qué puedes sanar a través de este proceso profundo.
				</p>
				<a href="https://www.juanpabloloaiza.com/agenda" target="_blank" rel="noopener" class="cta-btn">
					Agenda una sesión →
				</a>
				<div class="hero-divider"></div>
			</section>

			<section class="posts-section">
				<p class="section-label">Artículos</p>
				<ul class="posts-list">
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`} class="post-link">
									<article class="post-card">
										<div class="post-meta">
											<FormattedDate date={post.data.pubDate} />
										</div>
										<h2 class="post-title">{post.data.title}</h2>
										<p class="post-excerpt">{post.data.description}</p>
										<span class="post-cta">Leer artículo →</span>
									</article>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		text-align: center;
		padding: 4em 1em 2em;
	}

	.hero-ornament {
		color: #D4AF6A;
		letter-spacing: 0.6em;
		font-size: 0.7em;
		margin-bottom: 1.25em;
	}

	.hero h1 {
		font-size: 3em;
		font-weight: 400;
		color: #2C1F0E;
		line-height: 1.15;
		margin-bottom: 0.6em;
	}

	.hero-desc {
		max-width: 520px;
		margin: 0 auto 1.75em;
		color: #7A6840;
		font-size: 1.05em;
		line-height: 1.7;
	}

	.hero-divider {
		width: 80px;
		height: 1px;
		background: linear-gradient(90deg, transparent, #D4AF6A, transparent);
		margin: 2.5em auto 0;
	}

	.section-label {
		font-family: 'Cinzel', serif;
		font-size: 0.7em;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: #A89060;
		margin-bottom: 2em;
		margin-top: 3em;
	}

	.posts-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.posts-list li {
		border-bottom: 1px solid rgba(184, 149, 42, 0.12);
	}

	.posts-list li:first-child {
		border-top: 1px solid rgba(184, 149, 42, 0.12);
	}

	.post-link {
		display: block;
		text-decoration: none;
	}

	.post-card {
		padding: 2em 0;
		transition: padding-left 0.2s;
	}

	.post-link:hover .post-card {
		padding-left: 0.75em;
	}

	.post-meta {
		font-family: 'Cinzel', serif;
		font-size: 0.7em;
		letter-spacing: 0.1em;
		color: #A89060;
		margin-bottom: 0.6em;
	}

	.post-title {
		font-size: 1.45em;
		font-weight: 400;
		color: #2C1F0E;
		margin-bottom: 0.5em;
		line-height: 1.3;
		transition: color 0.2s;
	}

	.post-link:hover .post-title {
		color: #8B6914;
	}

	.post-excerpt {
		font-size: 0.92em;
		color: #7A6840;
		margin-bottom: 0.75em;
		line-height: 1.6;
	}

	.post-cta {
		font-family: 'Cinzel', serif;
		font-size: 0.72em;
		letter-spacing: 0.06em;
		color: #B8952A;
	}

	@media (max-width: 600px) {
		.hero h1 { font-size: 2.2em; }
	}
</style>
