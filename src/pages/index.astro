---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchModal from '../components/SearchModal.astro';
import { SITE_DESCRIPTION, SITE_TITLE, CATEGORY, EDITORIAL_PICKS, FEATURED_SLUG, SLUG_IMG } from '../consts';

import heroImg        from '../assets/blog/hero-meditacion-amanecer.jpg';
import imgVelasSeance from '../assets/blog/srt-velas-seance.jpg';
import imgVelaOscuridad from '../assets/blog/srt-vela-oscuridad.jpg';
import imgManosLuz    from '../assets/blog/srt-manos-luz.jpg';
import imgOjoMistico  from '../assets/blog/hipnosis-ojo-mistico.jpg';
import imgMeditacion  from '../assets/blog/rvp-meditacion.jpg';
import imgDefault     from '../assets/blog/hero-meditacion-amanecer.jpg';
import imgCosmos      from '../assets/blog/cosmos-estrellas.jpg';
import imgHumoOscuro  from '../assets/blog/srt-humo-oscuro.jpg';
import imgTerapia     from '../assets/blog/terapia-sesion.jpg';
import imgPortalLuz   from '../assets/blog/portal-luz.jpg';
import imgNinos       from '../assets/blog/ninos-naturaleza.jpg';
import imgMeditGrupal from '../assets/blog/meditacion-grupal.jpg';
import imgRitualFuego from '../assets/blog/ritual-fuego.jpg';
import imgSilueta     from '../assets/blog/silueta-espiritual.jpg';
import imgQueEs       from '../assets/blog/que-es-regresion.jpg';
import imgBeneficios  from '../assets/blog/beneficios-regresion.jpg';
import imgSesion      from '../assets/blog/sesion-regresion.jpg';
import type { ImageMetadata } from 'astro';

const IMG_REGISTRY: Record<string, ImageMetadata> = {
  'srt-velas-seance':        imgVelasSeance,
  'srt-vela-oscuridad':      imgVelaOscuridad,
  'srt-manos-luz':           imgManosLuz,
  'hipnosis-ojo-mistico':    imgOjoMistico,
  'rvp-meditacion':          imgMeditacion,
  'hero-meditacion-amanecer': imgDefault,
  'cosmos-estrellas':        imgCosmos,
  'srt-humo-oscuro':         imgHumoOscuro,
  'terapia-sesion':          imgTerapia,
  'portal-luz':              imgPortalLuz,
  'ninos-naturaleza':        imgNinos,
  'meditacion-grupal':       imgMeditGrupal,
  'ritual-fuego':            imgRitualFuego,
  'silueta-espiritual':      imgSilueta,
  'que-es-regresion':        imgQueEs,
  'beneficios-regresion':    imgBeneficios,
  'sesion-regresion':        imgSesion,
};

const EXPOSITOR_IMG: Record<string, ImageMetadata> = {
  'carl-wickland':   imgVelasSeance,
  'william-baldwin': imgManosLuz,
  'edith-fiore':     imgMeditacion,
  'alan-sanderson':  imgMeditacion,
  'srt':             imgVelaOscuridad,
  'hipnosis':        imgOjoMistico,
};

function getPostImage(id: string, heroImage: ImageMetadata | undefined, expositor?: string): ImageMetadata {
  if (heroImage) return heroImage;
  if (SLUG_IMG[id] && IMG_REGISTRY[SLUG_IMG[id]]) return IMG_REGISTRY[SLUG_IMG[id]];
  if (expositor && EXPOSITOR_IMG[expositor]) return EXPOSITOR_IMG[expositor];
  return imgDefault;
}

const allPosts = await getCollection('blog');

const featuredPost = allPosts.find(p => p.id === FEATURED_SLUG);
const featuredCat = featuredPost?.data.expositor ? CATEGORY[featuredPost.data.expositor] : undefined;
const featuredImg = featuredPost
  ? getPostImage(featuredPost.id, featuredPost.data.heroImage, featuredPost.data.expositor)
  : imgDefault;

const recentPosts = allPosts
  .filter(p => p.id !== FEATURED_SLUG)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 8);

const highlightPost = allPosts.find(p => p.id === EDITORIAL_PICKS[1]) ?? recentPosts[4];

const topPosts = EDITORIAL_PICKS
  .map(s => allPosts.find(p => p.id === s))
  .filter((p): p is NonNullable<typeof p> => p != null)
  .slice(0, 4);

const HUB_CARDS = [
  {
    roman: 'I',
    color: '#B8952A',
    title: 'Regresión a Vidas Pasadas',
    desc: 'Seis investigadores, técnicas y el fundamento científico de la terapia de regresión.',
    href: '/expositores',
    cta: 'Ver investigadores',
  },
  {
    roman: 'II',
    color: '#8B3A3A',
    title: 'Liberación Espiritual (SRT)',
    desc: 'Trabajo con entidades y energías adheridas al campo humano. Documentado desde 1924.',
    href: '/srt',
    cta: 'Explorar SRT',
  },
  {
    roman: 'III',
    color: '#4A6B8A',
    title: 'Hipnosis Clínica',
    desc: 'Historia, neurociencia, mitos y aplicaciones terapéuticas de la hipnosis.',
    href: '/hipnosis',
    cta: 'Explorar hipnosis',
  },
  {
    roman: 'IV',
    color: '#6B4A3A',
    title: 'Biblioteca',
    desc: 'Libros y recursos editorialmente seleccionados del campo.',
    href: '/libros',
    cta: 'Ver biblioteca',
  },
];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<SearchModal />

		<!-- Hero full-width -->
		<div class="hero-image-wrap">
			<Image src={heroImg} alt="Meditación espiritual al amanecer" width={1200} height={480} class="hero-img" />
			<div class="hero-image-overlay"></div>
		</div>

		<main class="home-main">

			<!-- ① HERO text + CTAs -->
			<section class="hero">
				<div class="hero-ornament">✦ ✦ ✦</div>
				<h1>Regresión a<br />Vidas Pasadas</h1>
				<p class="hero-desc">
					Un portal de conocimiento sobre la terapia de regresión, la hipnosis clínica
					y la liberación espiritual. Investigadores, técnicas y fundamentos documentados.
				</p>
				<div class="hero-actions">
					<a href="/blog" class="btn-primary">Explorar artículos</a>
					<a href="/blog/que-es-la-regresion-a-vidas-pasadas/" class="btn-secondary">¿Qué es la regresión?</a>
				</div>
				<div class="hero-divider"></div>
			</section>

			<!-- ② ARCHIVO DESTACADO -->
			{featuredPost && (
				<section class="featured-section">
					<div class="section-eyebrow">
						<span class="eyebrow-ornament">✦</span>
						<span class="eyebrow-text">Archivo destacado</span>
					</div>
					<a href={`/blog/${featuredPost.id}/`} class="featured-card">
						<div class="featured-img-wrap">
							<Image src={featuredImg} alt={featuredPost.data.title} width={640} height={400} class="featured-img" loading="eager" />
							{featuredCat && (
								<span class="featured-badge" style={`background:${featuredCat.color}`}>{featuredCat.label}</span>
							)}
						</div>
						<div class="featured-body">
							<h2 class="featured-title">{featuredPost.data.title}</h2>
							<p class="featured-excerpt">{featuredPost.data.description}</p>
							<span class="featured-cta">Continuar lectura →</span>
						</div>
					</a>
				</section>
			)}

			<!-- ③ PUBLICACIONES RECIENTES (2 columnas) -->
			{recentPosts.length > 0 && (
				<section class="recents-section">
					<div class="section-eyebrow">
						<span class="eyebrow-ornament">✦</span>
						<span class="eyebrow-text">Publicaciones recientes</span>
					</div>
					<div class="recents-grid">
						{recentPosts.map(post => {
							const cat = post.data.expositor ? CATEGORY[post.data.expositor] : undefined;
							const img = getPostImage(post.id, post.data.heroImage, post.data.expositor);
							return (
								<a href={`/blog/${post.id}/`} class="recent-card">
									<div class="recent-img-wrap">
										<Image src={img} alt={post.data.title} width={360} height={200} class="recent-img" loading="lazy" />
										{cat && <span class="recent-badge" style={`background:${cat.color}`}>{cat.label}</span>}
									</div>
									<h3 class="recent-title">{post.data.title}</h3>
								</a>
							);
						})}
					</div>
				</section>
			)}

			<!-- ④ LECTURA ESENCIAL (highlight card oscuro) -->
			{highlightPost && (
				<section class="highlight-section">
					<div class="highlight-card">
						<span class="highlight-label">Lectura esencial</span>
						<blockquote class="highlight-quote">"{highlightPost.data.description}"</blockquote>
						<a href={`/blog/${highlightPost.id}/`} class="highlight-link">{highlightPost.data.title} →</a>
					</div>
				</section>
			)}

			<!-- ⑤ LO ESENCIAL + CTA (2 columnas) -->
			<section class="bottom-section">
				<div class="mostread-col">
					<div class="section-eyebrow">
						<span class="eyebrow-ornament">✦</span>
						<span class="eyebrow-text">Lo esencial</span>
					</div>
					<ol class="mostread-list">
						{topPosts.map((post, i) => (
							<li class="mostread-item">
								<span class="mostread-num">0{i + 1}</span>
								<a href={`/blog/${post.id}/`} class="mostread-link">{post.data.title}</a>
							</li>
						))}
					</ol>
				</div>
				<div class="cta-col">
					<div class="cta-card">
						<span class="cta-label">Trabajo personal</span>
						<p class="cta-text">
							Si quieres explorar este proceso con un terapeuta especializado, conoce el trabajo de
							Juan Pablo Loaiza, certificado en RVP.
						</p>
						<a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener" class="cta-btn">
							juanpabloloaiza.com →
						</a>
					</div>
				</div>
			</section>

			<!-- ⑥ DISCIPLINAS DEL PORTAL (4 columnas) -->
			<section class="hubs-section">
				<div class="section-eyebrow">
					<span class="eyebrow-ornament">✦</span>
					<span class="eyebrow-text">Disciplinas del portal</span>
				</div>
				<div class="hubs-grid">
					{HUB_CARDS.map(h => (
						<a href={h.href} class="hub-card" style={`--hub-color:${h.color}`}>
							<span class="hub-roman">{h.roman}</span>
							<h3 class="hub-title">{h.title}</h3>
							<p class="hub-desc">{h.desc}</p>
							<span class="hub-cta">{h.cta} →</span>
						</a>
					))}
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
	.home-main { max-width: 1080px; padding-top: 0; }

	/* ——— Hero image ——— */
	.hero-image-wrap {
		position: relative;
		width: 100%;
		height: 420px;
		overflow: hidden;
	}

	.hero-img {
		width: 100%;
		height: 420px;
		object-fit: cover;
		object-position: center 30%;
		filter: sepia(20%) brightness(0.92) saturate(0.85);
		border-radius: 0;
	}

	.hero-image-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(to bottom, rgba(253,250,244,0) 40%, rgba(253,250,244,0.97) 100%);
	}

	/* ——— Hero text ——— */
	.hero { text-align: center; padding: 2.5em 1em 2em; }

	.hero-ornament { color: #D4AF6A; letter-spacing: 0.6em; font-size: 0.7em; margin-bottom: 1.25em; }

	.hero h1 { font-size: 3em; font-weight: 400; color: #2C1F0E; line-height: 1.15; margin-bottom: 0.6em; }

	.hero-desc { max-width: 520px; margin: 0 auto 1.75em; color: #7A6840; font-size: 1.05em; line-height: 1.7; }

	.hero-actions { display: flex; gap: 1em; justify-content: center; flex-wrap: wrap; margin-bottom: 2.5em; }

	.btn-primary {
		font-family: 'Cinzel', serif;
		font-size: 0.75em;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		padding: 0.85em 2em;
		background: #B8952A;
		color: #FDFAF4;
		text-decoration: none;
		border-radius: 4px;
		transition: background 0.2s, transform 0.15s;
	}
	.btn-primary:hover { background: #9A7A20; transform: translateY(-1px); }

	.btn-secondary {
		font-family: 'Cinzel', serif;
		font-size: 0.75em;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		padding: 0.85em 2em;
		border: 1px solid rgba(184,149,42,0.5);
		color: #8B6914;
		text-decoration: none;
		border-radius: 4px;
		transition: border-color 0.2s, color 0.2s, background 0.2s;
	}
	.btn-secondary:hover { border-color: #B8952A; color: #2C1F0E; background: rgba(184,149,42,0.06); }

	.hero-divider { width: 80px; height: 1px; background: linear-gradient(90deg, transparent, #D4AF6A, transparent); margin: 0 auto; }

	/* ——— Shared eyebrow ——— */
	.section-eyebrow { display: flex; align-items: center; gap: 0.75em; margin-bottom: 1.5em; }
	.eyebrow-ornament { color: #D4AF6A; font-size: 0.65em; }
	.eyebrow-text { font-family: 'Cinzel', serif; font-size: 0.68em; letter-spacing: 0.22em; text-transform: uppercase; color: #A89060; }

	/* ——— Shared section spacing ——— */
	.featured-section,
	.recents-section,
	.highlight-section,
	.bottom-section,
	.hubs-section { padding: 0 1.5em; margin-top: 4em; }

	/* ——— Featured article (Archivos históricos) ——— */
	.featured-card {
		display: grid;
		grid-template-columns: 1fr 1fr;
		text-decoration: none;
		color: inherit;
		background: #F5EFE0;
		border: 1px solid rgba(184,149,42,0.15);
		border-radius: 8px;
		overflow: hidden;
		transition: box-shadow 0.2s, transform 0.2s;
	}
	.featured-card:hover { box-shadow: 0 8px 30px rgba(44,31,14,0.12); transform: translateY(-2px); }

	.featured-img-wrap { position: relative; overflow: hidden; aspect-ratio: 4/3; }

	.featured-img { width: 100%; height: 100%; object-fit: cover; filter: sepia(10%) saturate(0.9); transition: transform 0.4s; }
	.featured-card:hover .featured-img { transform: scale(1.04); }

	.featured-badge {
		position: absolute;
		top: 1em;
		left: 1em;
		font-family: 'Cinzel', serif;
		font-size: 0.58em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 0.3em 0.7em;
		border-radius: 3px;
		color: #fff;
	}

	.featured-body {
		padding: 2.5em 2em;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 1em;
	}

	.featured-title { font-family: 'Crimson Text', serif; font-size: 1.75em; font-weight: 400; color: #2C1F0E; line-height: 1.25; margin: 0; }
	.featured-excerpt { font-size: 0.9em; color: #7A6840; line-height: 1.7; margin: 0; }
	.featured-cta { font-family: 'Cinzel', serif; font-size: 0.7em; letter-spacing: 0.1em; color: #B8952A; border-bottom: 1px solid rgba(184,149,42,0.4); display: inline-block; padding-bottom: 0.1em; }

	/* ——— Recent articles (2 cols) ——— */
	.recents-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5em;
	}

	.recent-card {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: inherit;
		background: #F5EFE0;
		border: 1px solid rgba(184,149,42,0.1);
		border-radius: 6px;
		overflow: hidden;
		transition: transform 0.2s, box-shadow 0.2s;
	}
	.recent-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(44,31,14,0.1); }

	.recent-img-wrap { position: relative; aspect-ratio: 16/9; overflow: hidden; }
	.recent-img { width: 100%; height: 100%; object-fit: cover; filter: sepia(10%) saturate(0.88); transition: transform 0.3s; }
	.recent-card:hover .recent-img { transform: scale(1.04); }

	.recent-badge {
		position: absolute;
		bottom: 0.5em;
		left: 0.5em;
		font-family: 'Cinzel', serif;
		font-size: 0.55em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 0.25em 0.6em;
		border-radius: 3px;
		color: #fff;
	}

	.recent-title { font-family: 'Crimson Text', serif; font-size: 1em; font-weight: 600; color: #2C1F0E; line-height: 1.4; padding: 1em 1.1em 1.25em; margin: 0; }
	.recent-card:hover .recent-title { color: #8B6914; }

	/* ——— Highlight (dark card) ——— */
	.highlight-card {
		background: #2C1F0E;
		border-radius: 8px;
		padding: 3em 3.5em;
		text-align: center;
	}

	.highlight-label { display: block; font-family: 'Cinzel', serif; font-size: 0.65em; letter-spacing: 0.22em; text-transform: uppercase; color: #B8952A; margin-bottom: 1.5em; }

	.highlight-quote {
		font-family: 'Crimson Text', serif;
		font-size: 1.5em;
		font-style: italic;
		color: #FDFAF4;
		line-height: 1.55;
		margin: 0 auto 2em;
		max-width: 680px;
	}

	.highlight-link { font-family: 'Cinzel', serif; font-size: 0.7em; letter-spacing: 0.12em; color: #D4AF6A; text-decoration: none; border-bottom: 1px solid rgba(212,175,106,0.4); padding-bottom: 0.1em; transition: color 0.2s; }
	.highlight-link:hover { color: #FDFAF4; }

	/* ——— Lo esencial + CTA (2 cols) ——— */
	.bottom-section { display: grid; grid-template-columns: 1fr 340px; gap: 3em; align-items: start; }

	.mostread-list { list-style: none; padding: 0; margin: 0; }

	.mostread-item { display: flex; align-items: baseline; gap: 1.25em; padding: 1em 0; border-bottom: 1px solid rgba(184,149,42,0.12); }

	.mostread-num { font-family: 'Cinzel', serif; font-size: 1.25em; color: rgba(184,149,42,0.3); flex-shrink: 0; line-height: 1; }

	.mostread-link { font-family: 'Crimson Text', serif; font-size: 1.05em; color: #3A2A10; text-decoration: none; line-height: 1.45; transition: color 0.2s; }
	.mostread-link:hover { color: #8B6914; }

	.cta-card { background: #F5EFE0; border: 1px solid rgba(184,149,42,0.2); border-radius: 8px; padding: 2em 1.75em; }

	.cta-label { display: block; font-family: 'Cinzel', serif; font-size: 0.65em; letter-spacing: 0.2em; text-transform: uppercase; color: #A89060; margin-bottom: 0.75em; }

	.cta-text { font-size: 0.88em; color: #5A4830; line-height: 1.7; margin-bottom: 1.5em; }

	.cta-btn {
		display: block;
		font-family: 'Cinzel', serif;
		font-size: 0.7em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		background: #B8952A;
		color: #FDFAF4;
		text-decoration: none;
		border-radius: 4px;
		padding: 0.9em 1.25em;
		text-align: center;
		transition: background 0.2s;
	}
	.cta-btn:hover { background: #9A7A20; }

	/* ——— Hub cards (4 cols) ——— */
	.hubs-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1.25em;
	}

	.hub-card {
		display: flex;
		flex-direction: column;
		gap: 0.6em;
		padding: 1.75em 1.5em;
		background: #F5EFE0;
		border: 1px solid rgba(184,149,42,0.12);
		border-top: 3px solid var(--hub-color);
		border-radius: 0 0 6px 6px;
		text-decoration: none;
		color: inherit;
		transition: transform 0.2s, box-shadow 0.2s;
	}
	.hub-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(44,31,14,0.1); }

	.hub-roman { font-family: 'Cinzel', serif; font-size: 1.5em; color: var(--hub-color); opacity: 0.4; line-height: 1; margin-bottom: 0.25em; }

	.hub-title { font-family: 'Cinzel', serif; font-size: 0.82em; font-weight: 500; color: #2C1F0E; line-height: 1.3; margin: 0; }

	.hub-desc { font-size: 0.82em; color: #7A6840; line-height: 1.6; flex: 1; margin: 0; }

	.hub-cta { font-family: 'Cinzel', serif; font-size: 0.65em; letter-spacing: 0.1em; color: var(--hub-color); margin-top: 0.5em; }

	/* ——— Responsive ——— */
	@media (max-width: 900px) {
		.featured-card { grid-template-columns: 1fr; }
		.featured-body { padding: 1.5em; }
		.bottom-section { grid-template-columns: 1fr; }
		.hubs-grid { grid-template-columns: repeat(2, 1fr); }
	}

	@media (max-width: 600px) {
		.hero h1 { font-size: 2.2em; }
		.hero-image-wrap { height: 300px; }
		.hero-img { height: 300px; }
		.recents-grid { grid-template-columns: 1fr; }
		.hubs-grid { grid-template-columns: 1fr; }
		.highlight-card { padding: 2em 1.25em; }
		.highlight-quote { font-size: 1.2em; }
	}
</style>
