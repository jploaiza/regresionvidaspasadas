---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchModal from '../components/SearchModal.astro';
import { SITE_DESCRIPTION, SITE_TITLE, CATEGORY, EDITORIAL_PICKS, FEATURED_SLUG, SLUG_IMG } from '../consts';

import heroImg        from '../assets/blog/stitch-hero-meditacion.png';
import imgVelasSeance from '../assets/blog/srt-velas-seance.jpg';
import imgVelaOscuridad from '../assets/blog/srt-vela-oscuridad.jpg';
import imgManosLuz    from '../assets/blog/srt-manos-luz.jpg';
import imgOjoMistico  from '../assets/blog/hipnosis-ojo-mistico.jpg';
import imgMeditacion  from '../assets/blog/rvp-meditacion.jpg';
import imgDefault     from '../assets/blog/stitch-hero-meditacion.png';
import imgCosmos      from '../assets/blog/cosmos-estrellas.jpg';
import imgHumoOscuro  from '../assets/blog/srt-humo-oscuro.jpg';
import imgTerapia     from '../assets/blog/terapia-sesion.jpg';
import imgPortalLuz   from '../assets/blog/portal-luz.jpg';
import imgNinos       from '../assets/blog/ninos-naturaleza.jpg';
import imgMeditGrupal from '../assets/blog/meditacion-grupal.jpg';
import imgRitualFuego from '../assets/blog/ritual-fuego.jpg';
import imgSilueta     from '../assets/blog/silueta-espiritual.jpg';
import imgQueEs       from '../assets/blog/que-es-regresion.jpg';
import imgBeneficios  from '../assets/blog/beneficios-regresion.jpg';
import imgSesion      from '../assets/blog/sesion-regresion.jpg';
import type { ImageMetadata } from 'astro';

const IMG_REGISTRY: Record<string, ImageMetadata> = {
  'srt-velas-seance':        imgVelasSeance,
  'srt-vela-oscuridad':      imgVelaOscuridad,
  'srt-manos-luz':           imgManosLuz,
  'hipnosis-ojo-mistico':    imgOjoMistico,
  'rvp-meditacion':          imgMeditacion,
  'hero-meditacion-amanecer': imgDefault,
  'cosmos-estrellas':        imgCosmos,
  'srt-humo-oscuro':         imgHumoOscuro,
  'terapia-sesion':          imgTerapia,
  'portal-luz':              imgPortalLuz,
  'ninos-naturaleza':        imgNinos,
  'meditacion-grupal':       imgMeditGrupal,
  'ritual-fuego':            imgRitualFuego,
  'silueta-espiritual':      imgSilueta,
  'que-es-regresion':        imgQueEs,
  'beneficios-regresion':    imgBeneficios,
  'sesion-regresion':        imgSesion,
};

const EXPOSITOR_IMG: Record<string, ImageMetadata> = {
  'carl-wickland':   imgVelasSeance,
  'william-baldwin': imgManosLuz,
  'edith-fiore':     imgMeditacion,
  'alan-sanderson':  imgMeditacion,
  'srt':             imgVelaOscuridad,
  'hipnosis':        imgOjoMistico,
};

function getPostImage(id: string, heroImage: ImageMetadata | undefined, expositor?: string): ImageMetadata {
  if (heroImage) return heroImage;
  if (SLUG_IMG[id] && IMG_REGISTRY[SLUG_IMG[id]]) return IMG_REGISTRY[SLUG_IMG[id]];
  if (expositor && EXPOSITOR_IMG[expositor]) return EXPOSITOR_IMG[expositor];
  return imgDefault;
}

const allPosts = await getCollection('blog');

const featuredPost = allPosts.find(p => p.id === FEATURED_SLUG);
const featuredCat = featuredPost?.data.expositor ? CATEGORY[featuredPost.data.expositor] : undefined;
const featuredImg = featuredPost
  ? getPostImage(featuredPost.id, featuredPost.data.heroImage, featuredPost.data.expositor)
  : imgDefault;

const recentPosts = allPosts
  .filter(p => p.id !== FEATURED_SLUG)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const topPosts = EDITORIAL_PICKS
  .map(s => allPosts.find(p => p.id === s))
  .filter((p): p is NonNullable<typeof p> => p != null)
  .slice(0, 4);

const casePost = allPosts.find(p => p.id === EDITORIAL_PICKS[1]) ?? topPosts[1];

const EXPEDIENTES = [
  { icon: 'history_edu', title: 'Regresión a Vidas Pasadas', desc: 'Investigación sobre memorias transgeneracionales y la continuidad de la consciencia a través del tiempo.', href: '/expositores', cta: 'Ver investigadores' },
  { icon: 'auto_awesome', title: 'Terapia de Liberación Espiritual', desc: 'Sistemas de limpieza energética y liberación de entidades adheridas al campo humano. Documentado desde 1924.', href: '/srt', cta: 'Explorar SRT' },
  { icon: 'psychology', title: 'Hipnosis Clínica', desc: 'Técnicas de inducción al subconsciente aplicadas al bienestar terapéutico y resolución de traumas.', href: '/hipnosis', cta: 'Explorar hipnosis' },
  { icon: 'menu_book', title: 'Biblioteca Editorial', desc: 'Libros esenciales: Brian Weiss, Michael Newton, Dolores Cannon, William Baldwin y más.', href: '/libros', cta: 'Ver biblioteca' },
];
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      /* Material Symbols */
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        font-family: 'Material Symbols Outlined';
        font-size: inherit;
        line-height: 1;
        display: inline-block;
        vertical-align: middle;
      }
    </style>
  </head>
  <body>
    <Header transparent={true} />
    <SearchModal />

    <!-- ① HERO PANTALLA COMPLETA -->
    <section class="home-hero">
      <div class="home-hero-bg">
        <Image src={heroImg} alt="Meditación espiritual al amanecer" width={1600} height={900} class="home-hero-img" loading="eager" />
        <div class="home-hero-overlay"></div>
      </div>
      <div class="home-hero-content">
        <div class="home-hero-badge">
          <span class="home-hero-badge-text">Portada Editorial</span>
        </div>
        <h1 class="home-hero-title">La Memoria del Alma<br/>a través del Tiempo</h1>
        <p class="home-hero-subtitle">
          "Una exploración académica sobre la regresión, la hipnosis y la liberación espiritual en la consciencia contemporánea."
        </p>
        <div class="home-hero-cta">
          <span class="home-hero-cta-label">Explorar el portal</span>
          <span class="material-symbols-outlined home-hero-arrow">arrow_downward</span>
        </div>
      </div>
    </section>

    <main class="home-main">

      <!-- Meta bar académica -->
      <div class="home-meta-bar">
        <span class="home-meta-left">Portal Independiente · Más de 60 artículos · Actualizado 2025</span>
        <span class="home-meta-right">Investigación en RVP · SRT · Hipnosis Clínica</span>
      </div>

      <!-- Grid editorial: 8 columnas contenido + 4 columnas sidebar -->
      <div class="home-grid">

        <!-- Contenido principal -->
        <div class="home-main-col">

          <!-- ARTÍCULO DESTACADO -->
          {featuredPost && (
            <article class="featured-article">
              <div class="featured-img-wrap">
                <Image src={featuredImg} alt={featuredPost.data.title} width={640} height={640} class="featured-img" loading="eager" />
              </div>
              <div class="featured-body">
                {featuredCat && (
                  <span class="featured-cat" style={`color: ${featuredCat.color}`}>{featuredCat.label}</span>
                )}
                <h2 class="featured-title">
                  <a href={`/blog/${featuredPost.id}/`}>{featuredPost.data.title}</a>
                </h2>
                <p class="featured-excerpt drop-cap">{featuredPost.data.description}</p>
                <a class="featured-read-more" href={`/blog/${featuredPost.id}/`}>
                  Continuar lectura <span class="material-symbols-outlined" style="font-size:0.9em">arrow_forward</span>
                </a>
              </div>
            </article>
          )}

          <!-- ARTÍCULOS SECUNDARIOS (2 columnas) -->
          <div class="secondary-grid">
            {recentPosts[0] && (() => {
              const cat = recentPosts[0].data.expositor ? CATEGORY[recentPosts[0].data.expositor] : undefined;
              const img = getPostImage(recentPosts[0].id, recentPosts[0].data.heroImage, recentPosts[0].data.expositor);
              return (
                <article class="secondary-card">
                  <div class="secondary-img-wrap">
                    <Image src={img} alt={recentPosts[0].data.title} width={480} height={270} class="secondary-img" loading="lazy" />
                  </div>
                  <h3 class="secondary-title">
                    <a href={`/blog/${recentPosts[0].id}/`}>{recentPosts[0].data.title}</a>
                  </h3>
                  <p class="secondary-desc">{recentPosts[0].data.description}</p>
                  {cat && <span class="secondary-cat">{cat.label}</span>}
                </article>
              );
            })()}

            {recentPosts[1] && (
              <article class="secondary-card secondary-card--text">
                <div class="secondary-icon-wrap">
                  <span class="material-symbols-outlined secondary-icon">psychology</span>
                </div>
                <h3 class="secondary-title">
                  <a href={`/blog/${recentPosts[1].id}/`}>{recentPosts[1].data.title}</a>
                </h3>
                <p class="secondary-desc">{recentPosts[1].data.description}</p>
                <span class="secondary-cat-label">Artículo · Investigación</span>
              </article>
            )}
          </div>

          <!-- ESTUDIO DE CASO (beige, horizontal) -->
          {casePost && (
            <article class="case-card">
              <div class="case-body">
                <span class="case-label">Lectura esencial</span>
                <h3 class="case-title">{casePost.data.title}</h3>
                <p class="case-quote">"{casePost.data.description}"</p>
              </div>
              <a href={`/blog/${casePost.id}/`} class="case-btn">Ver artículo</a>
            </article>
          )}

        </div>

        <!-- SIDEBAR -->
        <aside class="home-sidebar">

          <!-- Newsletter (decorativo) -->
          <div class="sidebar-newsletter">
            <div class="sidebar-newsletter-icon">
              <span class="material-symbols-outlined">mail</span>
            </div>
            <h4 class="sidebar-newsletter-title">Boletín de Investigación</h4>
            <p class="sidebar-newsletter-desc">Reciba mensualmente los últimos hallazgos sobre RVP, SRT y estudios de la consciencia.</p>
            <form class="sidebar-newsletter-form" onsubmit="return false;">
              <input class="sidebar-newsletter-input" type="email" placeholder="Correo electrónico" />
              <button class="sidebar-newsletter-btn" type="submit">Suscribirse al Portal</button>
            </form>
          </div>

          <!-- Lo más leído -->
          <div class="sidebar-mostread">
            <h4 class="sidebar-section-title">Lo más leído</h4>
            <ol class="sidebar-mostread-list">
              {topPosts.map((post, i) => (
                <li class="sidebar-mostread-item">
                  <span class="sidebar-mostread-num">0{i + 1}</span>
                  <a href={`/blog/${post.id}/`} class="sidebar-mostread-link">{post.data.title}</a>
                </li>
              ))}
            </ol>
          </div>

          <!-- CTA especialista (reemplaza "Podcast Editorial") -->
          <div class="sidebar-cta-dark">
            <span class="sidebar-cta-eyebrow">Trabajo personal</span>
            <h4 class="sidebar-cta-title">Sesiones con un especialista</h4>
            <p class="sidebar-cta-desc">Explora el proceso de regresión con un terapeuta certificado en RVP.</p>
            <a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener" class="sidebar-cta-link">
              juanpabloloaiza.com →
            </a>
          </div>

        </aside>
      </div>

      <div class="home-ornament"></div>

      <!-- EXPEDIENTES (4 cards grid) -->
      <section class="expedientes-section">
        <div class="expedientes-header">
          <h2 class="expedientes-title">Disciplinas del Portal</h2>
          <div class="expedientes-line"></div>
        </div>
        <div class="expedientes-grid">
          {EXPEDIENTES.map(e => (
            <a href={e.href} class="expediente-card">
              <span class="material-symbols-outlined expediente-icon">{e.icon}</span>
              <h5 class="expediente-title">{e.title}</h5>
              <p class="expediente-desc">{e.desc}</p>
              <span class="expediente-cta">{e.cta}</span>
            </a>
          ))}
        </div>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
  /* ——— Hero ——— */
  .home-hero {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 600px;
    padding-top: 72px; /* descontar altura del header absoluto */
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-sizing: border-box;
  }

  .home-hero-bg {
    position: absolute;
    inset: 0;
  }

  .home-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .home-hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
  }

  .home-hero-content {
    position: relative;
    z-index: 10;
    max-width: 800px;
    padding: 0 2em;
    text-align: center;
    color: #fff;
  }

  .home-hero-badge {
    display: inline-block;
    padding: 0.4em 1.2em;
    background: rgba(184,149,42,0.2);
    border: 1px solid rgba(184,149,42,0.4);
    border-radius: 100px;
    margin-bottom: 2em;
  }

  .home-hero-badge-text {
    font-family: 'Libre Caslon Text', serif;
    font-size: 0.52em;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #D4AF6A;
  }

  .home-hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5em, 6vw, 5.5em);
    font-weight: 700;
    color: #fff;
    line-height: 1.05;
    margin-bottom: 1em;
    text-shadow: 0 2px 12px rgba(0,0,0,0.3);
  }

  .home-hero-subtitle {
    font-family: 'EB Garamond', serif;
    font-size: clamp(1em, 2.5vw, 1.5em);
    font-style: italic;
    color: rgba(255,255,255,0.88);
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto 2.5em;
    text-shadow: 0 1px 8px rgba(0,0,0,0.3);
  }

  .home-hero-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5em;
  }

  .home-hero-cta-label {
    font-family: 'Libre Caslon Text', serif;
    font-size: 0.6em;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
  }

  .home-hero-arrow {
    font-size: 1.75em !important;
    color: #D4AF6A;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ——— Main container ——— */
  .home-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3em 2em 5em;
  }

  /* ——— Meta bar ——— */
  .home-meta-bar {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px solid rgba(184,149,42,0.12);
    padding-bottom: 1.25em;
    margin-bottom: 4em;
    gap: 1em;
    flex-wrap: wrap;
  }

  .home-meta-left,
  .home-meta-right {
    font-family: 'Libre Caslon Text', serif;
    font-size: 0.52em;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #7A6840;
  }

  /* ——— Grid editorial ——— */
  .home-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 4em;
    margin-bottom: 4em;
  }

  .home-main-col { min-width: 0; }

  /* ——— Featured article ——— */
  .featured-article {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5em;
    align-items: start;
    margin-bottom: 4em;
  }

  .featured-img-wrap {
    aspect-ratio: 1;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(44,31,14,0.12);
    border: 1px solid rgba(184,149,42,0.12);
  }

  .featured-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s;
  }
  .featured-img:hover { opacity: 0.9; }

  .featured-body { display: flex; flex-direction: column; gap: 0.75em; }

  .featured-cat {
    font-family: 'Libre Caslon Text', serif;
    font-size: 0.5em;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    display: block;
  }

  .featured-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.6em;
    font-weight: 700;
    line-height: 1.2;
    margin: 0;
  }

  .featured-title a { color: #2C1F0E; text-decoration: none; transition: color 0.2s; }
  .featured-title a:hover { color: #B8952A; text-decoration: none; }

  .featured-excerpt {
    font-family: 'EB Garamond', serif;
    font-size: 1.05em;
    color: #2C1F0E;
    line-height: 1.7;
    margin: 0;
  }

  .drop-cap::first-letter {
    float: left;
    font-family: 'Playfair Display', serif;
    font-size: 4em;
    line-height: 0.8;
    padding: 0.1em 0.3em 0 0;
    color: #B8952A;
    font-weight: 900;
  }

  .featured-read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: 'Libre Caslon Text', serif;
    font-size: 0.55em;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #B8952A;
    text-decoration: none;
    border-bottom: 1px solid rgba(184,149,42,0.4);
    padding-bottom: 0.1em;
    transition: color 0.2s;
  }
  .featured-read-more:hover { color: #8B6914; text-decoration: none; }

  /* ——— Secondary articles (2 cols) ——— */
  .secondary-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3em;
    margin-bottom: 4em;
  }

  .secondary-card { display: flex; flex-direction: column; gap: 0.75em; }

  .secondary-img-wrap { overflow: hidden; aspect-ratio: 16/9; margin-bottom: 0.25em; box-shadow: 0 4px 16px rgba(44,31,14,0.1); }
  .secondary-img { width: 100%; height: 100%; object-fit: cover; }

  .secondary-card--text { justify-content: space-between; border-left: 1px solid rgba(184,149,42,0.2); padding-left: 2em; }

  .secondary-icon-wrap { display: flex; align-items: center; justify-content: center; width: 44px; height: 44px; border-radius: 50%; background: #F5EFE0; }
  .secondary-icon { font-size: 1.3em !important; color: #B8952A; }

  .secondary-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.2em;
    font-weight: 700;
    line-height: 1.25;
    margin: 0;
  }
  .secondary-title a { color: #2C1F0E; text-decoration: none; }
  .secondary-title a:hover { color: #B8952A; text-decoration: none; }

  .secondary-desc { font-family: 'EB Garamond', serif; font-size: 0.9em; color: #7A6840; line-height: 1.6; margin: 0; font-style: italic; }

  .secondary-cat { font-family: 'Libre Caslon Text', serif; font-size: 0.48em; letter-spacing: 0.18em; text-transform: uppercase; color: #B8952A; }
  .secondary-cat-label { font-family: 'Libre Caslon Text', serif; font-size: 0.48em; letter-spacing: 0.18em; text-transform: uppercase; color: #7A6840; }

  /* ——— Case / estudio de caso ——— */
  .case-card {
    display: flex;
    align-items: center;
    gap: 2em;
    background: rgba(245,239,224,0.5);
    padding: 2em 2.5em;
    border: 1px solid rgba(184,149,42,0.12);
  }

  .case-body { flex: 1; }

  .case-label {
    font-family: 'Libre Caslon Text', serif;
    font-size: 0.5em;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #B8952A;
    display: block;
    margin-bottom: 0.5em;
    font-weight: 700;
  }

  .case-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.1em;
    font-weight: 700;
    color: #2C1F0E;
    margin: 0 0 0.5em;
  }

  .case-quote {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    color: #2C1F0E;
    font-size: 0.95em;
    line-height: 1.6;
    margin: 0;
  }

  .case-btn {
    white-space: nowrap;
    padding: 0.8em 1.75em;
    background: #2C1F0E;
    color: #FDFAF4;
    font-family: 'Libre Caslon Text', serif;
    font-size: 0.5em;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .case-btn:hover { background: #B8952A; text-decoration: none; color: #FDFAF4; }

  /* ——— Sidebar ——— */
  .home-sidebar { display: flex; flex-direction: column; gap: 3em; }

  /* Newsletter */
  .sidebar-newsletter {
    border: 2px solid rgba(184,149,42,0.3);
    padding: 2em;
    position: relative;
    text-align: center;
  }

  .sidebar-newsletter-icon {
    position: absolute;
    top: -1.25em;
    left: 50%;
    transform: translateX(-50%);
    background: #FDFAF4;
    padding: 0 0.75em;
  }
  .sidebar-newsletter-icon .material-symbols-outlined { font-size: 1.75em !important; color: #B8952A; }

  .sidebar-newsletter-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.1em;
    font-weight: 700;
    margin: 0.5em 0 0.75em;
  }

  .sidebar-newsletter-desc {
    font-family: 'EB Garamond', serif;
    font-size: 0.85em;
    font-style: italic;
    color: #7A6840;
    line-height: 1.6;
    margin-bottom: 1.25em;
  }

  .sidebar-newsletter-form { display: flex; flex-direction: column; gap: 0.75em; }

  .sidebar-newsletter-input {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(184,149,42,0.4);
    padding: 0.6em 0;
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-size: 0.9em;
    color: #2C1F0E;
    outline: none;
    width: 100%;
  }
  .sidebar-newsletter-input:focus { border-bottom-color: #B8952A; }
  .sidebar-newsletter-input::placeholder { color: #A89060; }

  .sidebar-newsletter-btn {
    padding: 0.8em;
    background: #B8952A;
    color: #FDFAF4;
    border: none;
    cursor: pointer;
    font-family: 'Libre Caslon Text', serif;
    font-size: 0.5em;
    letter-spacing: 0.18em;
