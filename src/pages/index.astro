---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchModal from '../components/SearchModal.astro';
import { SITE_DESCRIPTION, SITE_TITLE, CATEGORY, EDITORIAL_PICKS, SLUG_IMG } from '../consts';

import heroImg        from '../assets/blog/hero-meditacion-amanecer.jpg';
import imgVelasSeance from '../assets/blog/srt-velas-seance.jpg';
import imgVelaOscuridad from '../assets/blog/srt-vela-oscuridad.jpg';
import imgManosLuz    from '../assets/blog/srt-manos-luz.jpg';
import imgOjoMistico  from '../assets/blog/hipnosis-ojo-mistico.jpg';
import imgMeditacion  from '../assets/blog/rvp-meditacion.jpg';
import imgDefault     from '../assets/blog/hero-meditacion-amanecer.jpg';
import imgCosmos      from '../assets/blog/cosmos-estrellas.jpg';
import imgHumoOscuro  from '../assets/blog/srt-humo-oscuro.jpg';
import imgTerapia     from '../assets/blog/terapia-sesion.jpg';
import imgPortalLuz   from '../assets/blog/portal-luz.jpg';
import imgNinos       from '../assets/blog/ninos-naturaleza.jpg';
import imgMeditGrupal from '../assets/blog/meditacion-grupal.jpg';
import imgRitualFuego from '../assets/blog/ritual-fuego.jpg';
import imgSilueta     from '../assets/blog/silueta-espiritual.jpg';
import imgQueEs       from '../assets/blog/que-es-regresion.jpg';
import imgBeneficios  from '../assets/blog/beneficios-regresion.jpg';
import imgSesion      from '../assets/blog/sesion-regresion.jpg';
import type { ImageMetadata } from 'astro';

const IMG_REGISTRY: Record<string, ImageMetadata> = {
  'srt-velas-seance':        imgVelasSeance,
  'srt-vela-oscuridad':      imgVelaOscuridad,
  'srt-manos-luz':           imgManosLuz,
  'hipnosis-ojo-mistico':    imgOjoMistico,
  'rvp-meditacion':          imgMeditacion,
  'hero-meditacion-amanecer': imgDefault,
  'cosmos-estrellas':        imgCosmos,
  'srt-humo-oscuro':         imgHumoOscuro,
  'terapia-sesion':          imgTerapia,
  'portal-luz':              imgPortalLuz,
  'ninos-naturaleza':        imgNinos,
  'meditacion-grupal':       imgMeditGrupal,
  'ritual-fuego':            imgRitualFuego,
  'silueta-espiritual':      imgSilueta,
  'que-es-regresion':        imgQueEs,
  'beneficios-regresion':    imgBeneficios,
  'sesion-regresion':        imgSesion,
};

const EXPOSITOR_IMG: Record<string, ImageMetadata> = {
  'carl-wickland':   imgVelasSeance,
  'william-baldwin': imgManosLuz,
  'edith-fiore':     imgMeditacion,
  'alan-sanderson':  imgMeditacion,
  'srt':             imgVelaOscuridad,
  'hipnosis':        imgOjoMistico,
};

function getPostImage(id: string, heroImage: ImageMetadata | undefined, expositor?: string): ImageMetadata {
  if (heroImage) return heroImage;
  if (SLUG_IMG[id] && IMG_REGISTRY[SLUG_IMG[id]]) return IMG_REGISTRY[SLUG_IMG[id]];
  if (expositor && EXPOSITOR_IMG[expositor]) return EXPOSITOR_IMG[expositor];
  return imgDefault;
}

const allPosts = await getCollection('blog');
const picksData = EDITORIAL_PICKS.map(slug => allPosts.find(p => p.id === slug)).filter(Boolean);

const DISCIPLINES = [
  {
    title: 'Regresión a Vidas Pasadas',
    abbr: 'RVP',
    color: '#B8952A',
    bg: 'rgba(184,149,42,0.07)',
    desc: 'Técnica terapéutica que utiliza la hipnosis para acceder a memorias de vidas anteriores y resolver patrones que persisten en el presente.',
    href: '/expositores',
    cta: 'Ver investigadores →',
    articles: [
      { title: '¿Qué es la regresión a vidas pasadas?', href: '/blog/que-es-la-regresion-a-vidas-pasadas/' },
      { title: 'Beneficios de la terapia de regresión', href: '/blog/beneficios-terapia-regresion-vidas-pasadas/' },
      { title: '¿Qué esperar de una sesión?', href: '/blog/que-esperar-sesion-regresion-vidas-pasadas/' },
    ],
  },
  {
    title: 'Liberación Espiritual (SRT)',
    abbr: 'SRT',
    color: '#8B3A3A',
    bg: 'rgba(139,58,58,0.07)',
    desc: 'Protocolo terapéutico que trabaja con entidades o energías adheridas al campo humano, abordándolas con compasión y sin juicio.',
    href: '/srt',
    cta: 'Explorar SRT →',
    articles: [
      { title: '¿Qué es la terapia de liberación espiritual?', href: '/blog/srt-que-es/' },
      { title: 'Posesión y apego espiritual', href: '/blog/srt-posesiones-apego/' },
      { title: 'SRT vs. exorcismo: diferencias clave', href: '/blog/srt-exorcismo-vs-srt/' },
    ],
  },
  {
    title: 'Hipnosis Clínica',
    abbr: 'HIP',
    color: '#4A6B8A',
    bg: 'rgba(74,107,138,0.07)',
    desc: 'Estado de atención focalizada y sugestibilidad aumentada, documentado neurocientíficamente. Una herramienta terapéutica, no un espectáculo.',
    href: '/hipnosis',
    cta: 'Explorar hipnosis →',
    articles: [
      { title: '¿Qué es la hipnosis realmente?', href: '/blog/hipnosis-que-es-realmente/' },
      { title: 'Historia: de chamanes a Erickson', href: '/blog/hipnosis-origenes-mesmer-braid/' },
      { title: 'Mitos y realidades de la hipnosis', href: '/blog/hipnosis-mitos-y-realidades/' },
    ],
  },
];

const RESEARCHERS = [
  { name: 'Brian Weiss', role: 'Psiquiatra · RVP', initials: 'BW', color: '#B8952A', href: '/expositores' },
  { name: 'Michael Newton', role: 'Hipnólogo · LBL', initials: 'MN', color: '#B8952A', href: '/expositores' },
  { name: 'Dolores Cannon', role: 'Hipnóloga · QHHT', initials: 'DC', color: '#B8952A', href: '/expositores' },
  { name: 'Carl Wickland', role: 'Psiquiatra · SRT', initials: 'CW', color: '#8B3A3A', href: '/srt' },
  { name: 'Ian Stevenson', role: 'Investigador · Reencarnación', initials: 'IS', color: '#B8952A', href: '/expositores' },
  { name: 'Helen Wambach', role: 'Psicóloga · Hipnosis grupal', initials: 'HW', color: '#4A6B8A', href: '/hipnosis' },
];
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<SearchModal />
		<main>

			<!-- ① HERO -->
			<div class="hero-image-wrap">
				<Image src={heroImg} alt="Meditación espiritual al amanecer" width={1200} height={480} class="hero-img" />
				<div class="hero-image-overlay"></div>
			</div>
			<section class="hero">
				<div class="hero-ornament">✦ ✦ ✦</div>
				<h1>Regresión a<br />Vidas Pasadas</h1>
				<p class="hero-desc">
					Un portal de conocimiento sobre la terapia de regresión, la hipnosis clínica
					y la liberación espiritual. Investigadores, técnicas y fundamentos documentados.
				</p>
				<div class="hero-actions">
					<a href="/blog" class="btn-primary">Explorar artículos</a>
					<a href="/blog/que-es-la-regresion-a-vidas-pasadas/" class="btn-secondary">¿Qué es la regresión?</a>
				</div>
				<div class="hero-divider"></div>
			</section>

			<!-- ② TRES DISCIPLINAS -->
			<section class="disciplines-section">
				<p class="section-label">Las disciplinas</p>
				<div class="disciplines-grid">
					{DISCIPLINES.map(d => (
						<div class="discipline-card" style={`--disc-color: ${d.color}; --disc-bg: ${d.bg}`}>
							<div class="discipline-abbr">{d.abbr}</div>
							<h2 class="discipline-title">{d.title}</h2>
							<p class="discipline-desc">{d.desc}</p>
							<ul class="discipline-articles">
								{d.articles.map(a => (
									<li><a href={a.href}>{a.title}</a></li>
								))}
							</ul>
							<a href={d.href} class="discipline-cta">{d.cta}</a>
						</div>
					))}
				</div>
			</section>

			<!-- ③ INVESTIGADORES -->
			<section class="researchers-section">
				<p class="section-label">Investigadores</p>
				<div class="researchers-grid">
					{RESEARCHERS.map(r => (
						<a href={r.href} class="researcher-card">
							<div class="researcher-avatar" style={`background:${r.color}20; color:${r.color}; border-color:${r.color}30`}>
								{r.initials}
							</div>
							<div class="researcher-info">
								<span class="researcher-name">{r.name}</span>
								<span class="researcher-role">{r.role}</span>
							</div>
						</a>
					))}
				</div>
			</section>

			<!-- ④ ARTÍCULOS EDITORIALES -->
			{picksData.length > 0 && (
				<section class="picks-section">
					<p class="section-label">Artículos fundamentales</p>
					<div class="picks-grid">
						{picksData.map(post => {
							const cat = post!.data.expositor ? CATEGORY[post!.data.expositor] : undefined;
							const img = getPostImage(post!.id, post!.data.heroImage, post!.data.expositor);
							return (
								<a href={`/blog/${post!.id}/`} class="pick-card">
									<div class="pick-img">
										<Image src={img} alt={post!.data.title} width={420} height={240} loading="lazy" />
										{cat && (
											<span class="pick-badge" style={`background:${cat.color}; color:#fff`}>
												{cat.label}
											</span>
										)}
									</div>
									<div class="pick-body">
										<h3 class="pick-title">{post!.data.title}</h3>
										<p class="pick-excerpt">{post!.data.description}</p>
									</div>
								</a>
							);
						})}
					</div>
				</section>
			)}

			<!-- ⑤ CTA ESPECIALISTA -->
			<section class="specialist-cta">
				<p class="specialist-text">
					Si quieres explorar este proceso con un terapeuta especializado, conoce el trabajo de
					<a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener">Juan Pablo Loaiza</a>,
					terapeuta certificado en RVP.
				</p>
				<a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener" class="specialist-link">
					juanpabloloaiza.com →
				</a>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
	/* ——— Hero ——— */
	.hero-image-wrap {
		position: relative;
		width: 100%;
		height: 420px;
		overflow: hidden;
	}

	.hero-img {
		width: 100%;
		height: 420px;
		object-fit: cover;
		object-position: center 30%;
		filter: sepia(20%) brightness(0.92) saturate(0.85);
	}

	.hero-image-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(to bottom, rgba(253,250,244,0) 40%, rgba(253,250,244,0.97) 100%);
	}

	.hero {
		text-align: center;
		padding: 2.5em 1em 2em;
	}

	.hero-ornament {
		color: #D4AF6A;
		letter-spacing: 0.6em;
		font-size: 0.7em;
		margin-bottom: 1.25em;
	}

	.hero h1 {
		font-size: 3em;
		font-weight: 400;
		color: #2C1F0E;
		line-height: 1.15;
		margin-bottom: 0.6em;
	}

	.hero-desc {
		max-width: 520px;
		margin: 0 auto 1.75em;
		color: #7A6840;
		font-size: 1.05em;
		line-height: 1.7;
	}

	.hero-actions {
		display: flex;
		gap: 1em;
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: 2.5em;
	}

	.btn-primary {
		font-family: 'Cinzel', serif;
		font-size: 0.75em;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		padding: 0.85em 2em;
		background: #B8952A;
		color: #FDFAF4;
		text-decoration: none;
		border-radius: 4px;
		transition: background 0.2s, transform 0.15s;
	}

	.btn-primary:hover {
		background: #9A7A20;
		transform: translateY(-1px);
	}

	.btn-secondary {
		font-family: 'Cinzel', serif;
		font-size: 0.75em;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		padding: 0.85em 2em;
		border: 1px solid rgba(184,149,42,0.5);
		color: #8B6914;
		text-decoration: none;
		border-radius: 4px;
		transition: border-color 0.2s, color 0.2s, background 0.2s;
	}

	.btn-secondary:hover {
		border-color: #B8952A;
		color: #2C1F0E;
		background: rgba(184,149,42,0.06);
	}

	.hero-divider {
		width: 80px;
		height: 1px;
		background: linear-gradient(90deg, transparent, #D4AF6A, transparent);
		margin: 0 auto;
	}

	/* ——— Shared section label ——— */
	.section-label {
		font-family: 'Cinzel', serif;
		font-size: 0.68em;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: #A89060;
		margin-bottom: 1.5em;
	}

	/* ——— Disciplines ——— */
	.disciplines-section {
		max-width: 1040px;
		margin: 3.5em auto 0;
		padding: 0 1.5em;
	}

	.disciplines-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5em;
	}

	.discipline-card {
		background: var(--disc-bg);
		border: 1px solid var(--disc-color);
		border-left-width: 3px;
		border-radius: 6px;
		padding: 1.75em 1.5em;
	}

	.discipline-abbr {
		font-family: 'Cinzel', serif;
		font-size: 0.68em;
		letter-spacing: 0.18em;
		color: var(--disc-color);
		margin-bottom: 0.6em;
	}

	.discipline-title {
		font-family: 'Cinzel', serif;
		font-size: 0.95em;
		font-weight: 500;
		color: #2C1F0E;
		margin-bottom: 0.75em;
		line-height: 1.3;
	}

	.discipline-desc {
		font-size: 0.88em;
		color: #5A4830;
		line-height: 1.65;
		margin-bottom: 1.25em;
	}

	.discipline-articles {
		list-style: none;
		padding: 0;
		margin: 0 0 1.25em;
		border-top: 1px solid var(--disc-color);
		padding-top: 1em;
	}

	.discipline-articles li {
		margin-bottom: 0.4em;
	}

	.discipline-articles a {
		font-size: 0.82em;
		color: #7A5A20;
		text-decoration: none;
		line-height: 1.5;
		transition: color 0.2s;
	}

	.discipline-articles a:hover {
		color: var(--disc-color);
	}

	.discipline-articles a::before {
		content: '→ ';
		color: var(--disc-color);
		font-size: 0.9em;
	}

	.discipline-cta {
		font-family: 'Cinzel', serif;
		font-size: 0.7em;
		letter-spacing: 0.1em;
		color: var(--disc-color);
		text-decoration: none;
		border-bottom: 1px solid currentColor;
		padding-bottom: 0.1em;
		transition: opacity 0.2s;
	}

	.discipline-cta:hover { opacity: 0.7; }

	/* ——— Researchers ——— */
	.researchers-section {
		max-width: 1040px;
		margin: 4em auto 0;
		padding: 0 1.5em;
	}

	.researchers-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1em;
	}

	.researcher-card {
		display: flex;
		align-items: center;
		gap: 1em;
		padding: 1em 1.25em;
		background: #F5EFE0;
		border-radius: 6px;
		text-decoration: none;
		border: 1px solid rgba(184,149,42,0.12);
		transition: border-color 0.2s, transform 0.15s;
	}

	.researcher-card:hover {
		border-color: rgba(184,149,42,0.4);
		transform: translateY(-1px);
	}

	.researcher-avatar {
		flex-shrink: 0;
		width: 42px;
		height: 42px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: 'Cinzel', serif;
		font-size: 0.72em;
		font-weight: 600;
		letter-spacing: 0.04em;
		border: 1px solid;
	}

	.researcher-info {
		display: flex;
		flex-direction: column;
		gap: 0.2em;
	}

	.researcher-name {
		font-family: 'Cinzel', serif;
		font-size: 0.78em;
		color: #2C1F0E;
		letter-spacing: 0.03em;
	}

	.researcher-role {
		font-size: 0.72em;
		color: #8A7055;
	}

	/* ——— Editorial picks ——— */
	.picks-section {
		max-width: 1040px;
		margin: 4em auto 0;
		padding: 0 1.5em;
	}

	.picks-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5em;
	}

	.pick-card {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		border-radius: 8px;
		overflow: hidden;
		background: #F5EFE0;
		border: 1px solid rgba(184,149,42,0.1);
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.pick-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 24px rgba(44,31,14,0.1);
	}

	.pick-img {
		position: relative;
		aspect-ratio: 16 / 9;
		overflow: hidden;
	}

	.pick-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: sepia(10%) saturate(0.9);
		transition: transform 0.3s;
	}

	.pick-card:hover .pick-img img {
		transform: scale(1.04);
	}

	.pick-badge {
		position: absolute;
		bottom: 0.6em;
		left: 0.6em;
		font-family: 'Cinzel', serif;
		font-size: 0.58em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 0.25em 0.6em;
		border-radius: 3px;
	}

	.pick-body {
		padding: 1.1em 1.25em 1.25em;
	}

	.pick-title {
		font-family: 'Cinzel', serif;
		font-size: 0.88em;
		font-weight: 400;
		color: #2C1F0E;
		line-height: 1.35;
		margin-bottom: 0.5em;
		transition: color 0.2s;
	}

	.pick-card:hover .pick-title { color: #8B6914; }

	.pick-excerpt {
		font-size: 0.82em;
		color: #7A6840;
		line-height: 1.55;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* ——— Specialist CTA ——— */
	.specialist-cta {
		max-width: 560px;
		margin: 4.5em auto 1em;
		padding: 1.75em 2em;
		background: #F5EFE0;
		border: 1px solid rgba(184,149,42,0.25);
		border-radius: 8px;
		text-align: center;
	}

	.specialist-text {
		font-size: 0.9em;
		color: #5A4830;
		line-height: 1.7;
		margin-bottom: 1.25em;
	}

	.specialist-text a {
		color: #8B6914;
		text-decoration: none;
	}

	.specialist-text a:hover { text-decoration: underline; }

	.specialist-link {
		font-family: 'Cinzel', serif;
		font-size: 0.72em;
		letter-spacing: 0.12em;
		color: #B8952A;
		text-decoration: none;
		border-bottom: 1px solid rgba(184,149,42,0.4);
		padding-bottom: 0.15em;
		transition: color 0.2s;
	}

	.specialist-link:hover { color: #2C1F0E; }

	/* ——— Responsive ——— */
	@media (max-width: 860px) {
		.disciplines-grid { grid-template-columns: 1fr; }
		.researchers-grid { grid-template-columns: repeat(2, 1fr); }
		.picks-grid { grid-template-columns: repeat(2, 1fr); }
	}

	@media (max-width: 560px) {
		.hero h1 { font-size: 2.2em; }
		.researchers-grid { grid-template-columns: 1fr; }
		.picks-grid { grid-template-columns: 1fr; }
		.hero-image-wrap { height: 300px; }
		.hero-img { height: 300px; }
	}
</style>
