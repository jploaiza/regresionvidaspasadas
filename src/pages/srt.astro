---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import headerImg from '../assets/blog/srt-velas-seance.jpg';

const allPosts = await getCollection('blog');

const EXPOSITORES_SRT = [
  {
    slug: 'carl-wickland',
    nombre: 'Carl Wickland',
    periodo: '1861 – 1945',
    rol: 'El pionero',
    descripcion: 'Psiquiatra sueco-americano que documentó más de 30 años de sesiones de liberación espiritual junto a su esposa Anna, la médium que hizo posible todo su trabajo. Su libro "Thirty Years Among the Dead" (1924) es el texto fundacional del campo.',
    libro: 'Thirty Years Among the Dead (1924)',
  },
  {
    slug: 'william-baldwin',
    nombre: 'William Baldwin',
    periodo: '1939 – 2004',
    rol: 'El sistematizador',
    descripcion: 'Psicólogo y exdentista que desarrolló los protocolos más completos y sistemáticos del campo. Su "Spirit Releasement Therapy: A Technique Manual" (1992) es la referencia técnica definitiva. Creó la taxonomía de entidades: humanas, oscuras, no humanas y fragmentos del alma.',
    libro: 'Spirit Releasement Therapy (1992)',
  },
  {
    slug: 'edith-fiore',
    nombre: 'Edith Fiore',
    periodo: '1930s –',
    rol: 'La psicóloga clínica',
    descripcion: 'PhD de la Universidad de Miami, con más de 30 años de práctica en California. Primera psicóloga con credenciales convencionales en documentar sistemáticamente la posesión espiritual desde una perspectiva terapéutica. Formó a más de 2.000 profesionales.',
    libro: 'The Unquiet Dead (1987)',
  },
  {
    slug: 'alan-sanderson',
    nombre: 'Alan Sanderson',
    periodo: '1930s –',
    rol: 'El psiquiatra institucional',
    descripcion: 'Psiquiatra formado en el Hospital St. Thomas de Londres. Introdujo la liberación espiritual en el NHS y presentó su trabajo al Royal College of Psychiatrists. Fundó la Spirit Release Foundation (2000–2013).',
    libro: 'Psychiatry and the Spirit World',
  },
];

const TEMAS_SRT = [
  { slug: 'srt-que-es', titulo: '¿Qué es la SRT?' },
  { slug: 'srt-posesiones-apego', titulo: 'Posesión y apego espiritual' },
  { slug: 'srt-entidades-oscuras-demonios', titulo: '¿Existen los demonios?' },
  { slug: 'srt-exorcismo-vs-srt', titulo: 'Exorcismo vs. SRT' },
  { slug: 'srt-extraterrestres-entidades', titulo: 'Entidades extraterrestres' },
  { slug: 'srt-magia-negra-mal-de-ojo', titulo: 'Magia negra y mal de ojo' },
  { slug: 'srt-y-regresion', titulo: 'SRT y Regresión: la conexión' },
];

function getArticulosPorExpositor(slug: string) {
  return allPosts
    .filter(p => p.data.expositor === slug)
    .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());
}

function getArticuloPorSlug(slug: string) {
  return allPosts.find(p => p.id === slug || p.id === `${slug}.md`);
}

const SITEURL = 'https://www.regresionvidaspasadas.com';
const HUB_URL = `${SITEURL}/srt/`;

const srtPosts = allPosts.filter(p =>
  ['carl-wickland','william-baldwin','edith-fiore','alan-sanderson','srt'].includes(p.data.expositor ?? '') ||
  TEMAS_SRT.some(t => p.id === t.slug || p.id === `${t.slug}.md`)
).sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

const hubSchema = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${HUB_URL}#collectionpage`,
    name: 'Terapia de Liberación Espiritual (SRT)',
    description: 'Portal temático sobre Spirit Releasement Therapy: posesiones, entidades y los principales referentes del campo.',
    url: HUB_URL,
    inLanguage: 'es',
    publisher: { '@id': `${SITEURL}/#organization` },
    hasPart: srtPosts.map(p => ({
      '@type': 'Article',
      '@id': `${SITEURL}/blog/${p.id}/#article`,
      name: p.data.title,
      url: `${SITEURL}/blog/${p.id}/`,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITEURL },
      { '@type': 'ListItem', position: 2, name: 'SRT', item: HUB_URL },
    ],
  },
]);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead
      title="Terapia de Liberación Espiritual (SRT)"
      description="Todo sobre la Spirit Releasement Therapy: posesiones, entidades, magia negra, ataques psíquicos y los grandes referentes del campo — Carl Wickland, William Baldwin, Edith Fiore y Alan Sanderson."
    />
    <script type="application/ld+json" set:html={hubSchema}></script>
  </head>
  <body>
    <Header />

    <div class="page-hero">
      <Image src={headerImg} alt="Velas encendidas en oscuridad — Terapia de Liberación Espiritual" width={1200} height={420} class="hero-img" />
      <div class="hero-overlay">
        <span class="hero-eyebrow">Disciplina · SRT</span>
        <h1>Terapia de Liberación Espiritual</h1>
        <p class="hero-desc">Trabaja con entidades que se adhieren al campo energético humano y las libera con compasión, no con combate. Documentada desde 1924.</p>
      </div>
    </div>

    <main class="hub-main">

      <section class="cards-section">
        <div class="section-eyebrow">
          <span class="eyebrow-ornament">✦</span>
          <span class="eyebrow-text">Referentes del campo</span>
        </div>
        <div class="cards-grid">
          {EXPOSITORES_SRT.map(exp => {
            const articulos = getArticulosPorExpositor(exp.slug);
            const firstArt = articulos[0];
            return (
              <a href={firstArt ? `/blog/${firstArt.id}/` : '#'} class="hub-card">
                <span class="card-initial">{exp.nombre[0]}</span>
                <div class="card-body">
                  <span class="card-role">{exp.rol} · {exp.periodo}</span>
                  <h3 class="card-title">{exp.nombre}</h3>
                  <p class="card-desc">{exp.descripcion}</p>
                  <span class="card-cta">Ver artículos →</span>
                </div>
              </a>
            );
          })}
        </div>
      </section>

      <section class="cards-section">
        <div class="section-eyebrow">
          <span class="eyebrow-ornament">✦</span>
          <span class="eyebrow-text">Conceptos y fenómenos</span>
        </div>
        <div class="cards-grid">
          {TEMAS_SRT.map(tema => {
            const art = getArticuloPorSlug(tema.slug);
            if (!art) return null;
            return (
              <a href={`/blog/${art.id}/`} class="hub-card hub-card--tema">
                <span class="card-symbol">✦</span>
                <div class="card-body">
                  <h3 class="card-title">{tema.titulo}</h3>
                  {art.data.description && <p class="card-desc">{art.data.description}</p>}
                  <span class="card-cta">Leer artículo →</span>
                </div>
              </a>
            );
          })}
        </div>
      </section>

      <div class="hub-cta">
        <span class="hub-cta-label">¿Quieres trabajar con un terapeuta?</span>
        <p>Conoce el trabajo de <a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener">Juan Pablo Loaiza</a>, especialista en liberación espiritual y regresión.</p>
        <a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener" class="hub-cta-btn">juanpabloloaiza.com →</a>
      </div>

    </main>
    <Footer />
  </body>
</html>

<style>
  /* ——— Hero ——— */
  .page-hero { position: relative; width: 100%; height: 420px; overflow: hidden; }
  .hero-img { width: 100%; height: 420px; object-fit: cover; filter: sepia(25%) brightness(0.50); display: block; border-radius: 0; }
  .hero-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 3em 2em;
    text-align: center;
    background: linear-gradient(to bottom, rgba(44,10,10,0.1) 0%, rgba(44,10,10,0.72) 100%);
  }
  .hero-eyebrow { font-family: 'Cinzel', serif; font-size: 0.62em; letter-spacing: 0.22em; text-transform: uppercase; color: #E08080; margin-bottom: 0.75em; }
  .hero-overlay h1 { font-family: 'Cinzel', serif; font-size: 2.6em; font-weight: 400; color: #FDFAF4; margin-bottom: 0.4em; text-shadow: 0 2px 12px rgba(0,0,0,0.5); }
  .hero-desc { color: rgba(253,250,244,0.8); font-size: 0.95em; max-width: 540px; line-height: 1.65; margin: 0; }

  /* ——— Main ——— */
  .hub-main { max-width: 1080px; margin: 0 auto; padding: 4em 1.5em 5em; }

  /* ——— Eyebrow ——— */
  .section-eyebrow { display: flex; align-items: center; gap: 0.75em; margin-bottom: 1.5em; }
  .eyebrow-ornament { color: #D4AF6A; font-size: 0.65em; }
  .eyebrow-text { font-family: 'Cinzel', serif; font-size: 0.68em; letter-spacing: 0.22em; text-transform: uppercase; color: #A89060; }

  /* ——— Cards section ——— */
  .cards-section { margin-bottom: 3.5em; }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25em;
  }

  .hub-card {
    display: flex;
    flex-direction: column;
    gap: 0.75em;
    padding: 1.75em 1.5em;
    background: #F5EFE0;
    border: 1px solid rgba(184,149,42,0.15);
    border-top: 3px solid #8B3A3A;
    border-radius: 0 0 6px 6px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .hub-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(44,10,10,0.1); }

  .hub-card--tema { border-top-color: #B8952A; }
  .hub-card--tema .card-cta { color: #B8952A; }

  .card-initial {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: rgba(139,58,58,0.12);
    border: 1px solid rgba(139,58,58,0.25);
    color: #8B3A3A;
    font-family: 'Cinzel', serif;
    font-size: 1.1em;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .card-symbol { font-size: 0.9em; color: #B8952A; }

  .card-body { display: flex; flex-direction: column; gap: 0.4em; flex: 1; }

  .card-role { font-family: 'Cinzel', serif; font-size: 0.6em; letter-spacing: 0.12em; text-transform: uppercase; color: #8B3A3A; }

  .card-title { font-family: 'Cinzel', serif; font-size: 0.88em; font-weight: 400; color: #2C1F0E; line-height: 1.3; margin: 0; }

  .card-desc {
    font-size: 0.82em;
    color: #7A6840;
    line-height: 1.6;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-cta { font-family: 'Cinzel', serif; font-size: 0.62em; letter-spacing: 0.1em; color: #8B3A3A; margin-top: 0.5em; }

  /* ——— Hub CTA ——— */
  .hub-cta {
    background: #F5EFE0;
    border: 1px solid rgba(184,149,42,0.2);
    border-radius: 8px;
    padding: 2.5em 2em;
    text-align: center;
    margin-top: 2em;
  }
  .hub-cta-label { display: block; font-family: 'Cinzel', serif; font-size: 0.68em; letter-spacing: 0.18em; text-transform: uppercase; color: #A89060; margin-bottom: 0.75em; }
  .hub-cta p { font-size: 0.9em; color: #5A4830; line-height: 1.7; margin-bottom: 1.5em; }
  .hub-cta a { color: #8B6914; text-decoration: none; }
  .hub-cta a:hover { text-decoration: underline; }
  .hub-cta-btn {
    display: inline-block;
    font-family: 'Cinzel', serif;
    font-size: 0.72em;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: #B8952A;
    color: #FDFAF4 !important;
    text-decoration: none !important;
    border-radius: 4px;
    padding: 0.85em 2em;
    transition: background 0.2s;
  }
  .hub-cta-btn:hover { background: #9A7A20 !important; }

  @media (max-width: 860px) {
    .cards-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .hero-overlay h1 { font-size: 1.9em; }
    .page-hero, .hero-img { height: 320px; }
    .cards-grid { grid-template-columns: 1fr; }
  }
</style>
