---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import headerImg from '../assets/blog/srt-velas-seance.jpg';

const allPosts = await getCollection('blog');

const EXPOSITORES_SRT = [
  {
    slug: 'carl-wickland',
    icon: 'person',
    nombre: 'Carl Wickland',
    periodo: '1861 – 1945',
    rol: 'El pionero',
    descripcion: 'Psiquiatra que documentó más de 30 años de sesiones de liberación espiritual. Su "Thirty Years Among the Dead" (1924) es el texto fundacional del campo.',
  },
  {
    slug: 'william-baldwin',
    icon: 'psychology',
    nombre: 'William Baldwin',
    periodo: '1939 – 2004',
    rol: 'El sistematizador',
    descripcion: 'Psicólogo que desarrolló los protocolos más completos del campo. Creó la taxonomía de entidades: humanas, oscuras, no humanas y fragmentos del alma.',
  },
  {
    slug: 'edith-fiore',
    icon: 'person',
    nombre: 'Edith Fiore',
    periodo: '1930s –',
    rol: 'La psicóloga clínica',
    descripcion: 'PhD de la Universidad de Miami. Primera psicóloga con credenciales convencionales en documentar sistemáticamente la posesión espiritual. Formó a más de 2.000 profesionales.',
  },
  {
    slug: 'alan-sanderson',
    icon: 'local_hospital',
    nombre: 'Alan Sanderson',
    periodo: '1930s –',
    rol: 'El psiquiatra institucional',
    descripcion: 'Psiquiatra formado en el Hospital St. Thomas de Londres. Introdujo la liberación espiritual en el NHS. Fundó la Spirit Release Foundation.',
  },
];

const TEMAS_SRT = [
  { slug: 'srt-que-es', icon: 'help_outline', titulo: '¿Qué es la SRT?' },
  { slug: 'srt-posesiones-apego', icon: 'link', titulo: 'Posesión y apego espiritual' },
  { slug: 'srt-entidades-oscuras-demonios', icon: 'dark_mode', titulo: '¿Existen los demonios?' },
  { slug: 'srt-exorcismo-vs-srt', icon: 'compare_arrows', titulo: 'Exorcismo vs. SRT' },
  { slug: 'srt-extraterrestres-entidades', icon: 'travel_explore', titulo: 'Entidades extraterrestres' },
  { slug: 'srt-magia-negra-mal-de-ojo', icon: 'remove_red_eye', titulo: 'Magia negra y mal de ojo' },
  { slug: 'srt-y-regresion', icon: 'auto_awesome', titulo: 'SRT y Regresión: la conexión' },
];

function getArticulosPorExpositor(slug: string) {
  return allPosts
    .filter(p => p.data.expositor === slug)
    .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());
}

function getArticuloPorSlug(slug: string) {
  return allPosts.find(p => p.id === slug || p.id === `${slug}.md`);
}

const SITEURL = 'https://www.regresionvidaspasadas.com';
const HUB_URL = `${SITEURL}/srt/`;

const srtPosts = allPosts.filter(p =>
  ['carl-wickland','william-baldwin','edith-fiore','alan-sanderson','srt'].includes(p.data.expositor ?? '') ||
  TEMAS_SRT.some(t => p.id === t.slug || p.id === `${t.slug}.md`)
).sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

const hubSchema = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${HUB_URL}#collectionpage`,
    name: 'Terapia de Liberación Espiritual (SRT)',
    description: 'Portal temático sobre Spirit Releasement Therapy: posesiones, entidades y los principales referentes del campo.',
    url: HUB_URL,
    inLanguage: 'es',
    publisher: { '@id': `${SITEURL}/#organization` },
    hasPart: srtPosts.map(p => ({
      '@type': 'Article',
      '@id': `${SITEURL}/blog/${p.id}/#article`,
      name: p.data.title,
      url: `${SITEURL}/blog/${p.id}/`,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITEURL },
      { '@type': 'ListItem', position: 2, name: 'SRT', item: HUB_URL },
    ],
  },
]);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead
      title="Terapia de Liberación Espiritual (SRT)"
      description="Todo sobre la Spirit Releasement Therapy: posesiones, entidades, magia negra, ataques psíquicos y los grandes referentes del campo — Carl Wickland, William Baldwin, Edith Fiore y Alan Sanderson."
    />
    <script type="application/ld+json" set:html={hubSchema}></script>
    <style>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        font-family: 'Material Symbols Outlined';
        line-height: 1;
        display: inline-block;
        vertical-align: middle;
        color: #B8952A;
      }
      .ornament { height: 1px; background: linear-gradient(90deg, transparent, #B8952A, transparent); width: 100%; margin: 2.5em 0; }
      .card-hover { transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.4s ease, border-color 0.3s; }
      .card-hover:hover { transform: translateY(-4px); box-shadow: 0 20px 25px -5px rgba(44,31,14,0.07); border-color: rgba(184,149,42,0.55); }
    </style>
  </head>
  <body>
    <Header />

    <!-- Hero 614px -->
    <section class="hub-hero">
      <div class="hub-hero-bg">
        <Image src={headerImg} alt="Velas encendidas — Terapia de Liberación Espiritual" width={1400} height={614} class="hub-hero-img" />
        <div class="hub-hero-overlay"></div>
      </div>
      <div class="hub-hero-content">
        <span class="hub-hero-eyebrow">Exploración Académica</span>
        <h1 class="hub-hero-title">Terapia de Liberación Espiritual</h1>
        <p class="hub-hero-desc">Trabaja con entidades que se adhieren al campo energético humano y las libera con compasión, no con combate. Documentada desde 1924.</p>
        <div class="hub-hero-line"></div>
      </div>
    </section>

    <main class="hub-main">

      <!-- Índice editorial -->
      <section class="hub-index-section">
        <div class="hub-index-header">
          <h2 class="hub-index-title">Índice Editorial</h2>
          <div class="hub-index-meta">
            <div class="hub-index-line"></div>
            <span class="hub-index-label">Referentes del campo</span>
            <div class="hub-index-line"></div>
          </div>
        </div>

        <div class="hub-cards-grid">
          {EXPOSITORES_SRT.map(exp => {
            const articulos = getArticulosPorExpositor(exp.slug);
            const firstArt = articulos[0];
            return (
              <a href={firstArt ? `/blog/${firstArt.id}/` : '#'} class="hub-card card-hover">
                <div class="hub-card-icon">
                  <span class="material-symbols-outlined">{exp.icon}</span>
                </div>
                <h3 class="hub-card-title">{exp.nombre}</h3>
                <p class="hub-card-desc">{exp.descripcion}</p>
                <span class="hub-card-cta">Ver artículos</span>
              </a>
            );
          })}
        </div>
      </section>

      <div class="ornament"></div>

      <!-- Conceptos y fenómenos -->
      <section class="hub-index-section">
        <div class="hub-index-header">
          <h2 class="hub-index-title">Conceptos y Fenómenos</h2>
          <div class="hub-index-meta">
            <div class="hub-index-line"></div>
            <span class="hub-index-label">Temas del área</span>
            <div class="hub-index-line"></div>
          </div>
        </div>

        <div class="hub-cards-grid">
          {TEMAS_SRT.map(tema => {
            const art = getArticuloPorSlug(tema.slug);
            if (!art) return null;
            return (
              <a href={`/blog/${art.id}/`} class="hub-card hub-card--tema card-hover">
                <div class="hub-card-icon hub-card-icon--tema">
                  <span class="material-symbols-outlined">{tema.icon}</span>
                </div>
                <h3 class="hub-card-title">{tema.titulo}</h3>
                {art.data.description && <p class="hub-card-desc">{art.data.description}</p>}
                <span class="hub-card-cta">Leer artículo</span>
              </a>
            );
          })}
        </div>
      </section>

      <!-- CTA terapeuta -->
      <section class="hub-cta-section">
        <div class="ornament opacity-50"></div>
        <h3 class="hub-cta-title">¿Quieres explorar este proceso?</h3>
        <p class="hub-cta-desc">
          Conoce el trabajo de <a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener">Juan Pablo Loaiza</a>,
          terapeuta especializado en liberación espiritual y regresión a vidas pasadas.
        </p>
        <a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener" class="hub-cta-btn">Conocer al especialista</a>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
  /* Hero */
  .hub-hero { position: relative; width: 100%; height: 614px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .hub-hero-bg { position: absolute; inset: 0; }
  .hub-hero-img { width: 100%; height: 100%; object-fit: cover; object-position: center; max-width: none; border-radius: 0; display: block; }
  .hub-hero-overlay { position: absolute; inset: 0; background: rgba(44,31,14,0.42); }
  .hub-hero-content { position: relative; z-index: 10; text-align: center; padding: 0 2em; max-width: 700px; }
  .hub-hero-eyebrow { font-family: 'Libre Caslon Text', serif; color: rgba(255,255,255,0.9); letter-spacing: 0.28em; font-size: 0.55em; text-transform: uppercase; display: block; margin-bottom: 1em; }
  .hub-hero-title { font-family: 'Playfair Display', serif; font-size: clamp(2em, 6vw, 4em); font-weight: 700; color: #fff; margin: 0 0 0.6em; line-height: 1.1; }
  .hub-hero-desc { font-family: 'EB Garamond', serif; font-size: 1.1em; font-style: italic; color: rgba(255,255,255,0.8); max-width: 520px; margin: 0 auto 1.5em; line-height: 1.65; }
  .hub-hero-line { width: 6em; height: 1px; background: #B8952A; margin: 0 auto; }

  /* Main */
  .hub-main { max-width: 1100px; margin: 0 auto; padding: 5em 2em 6em; }

  /* Section header */
  .hub-index-section { margin-bottom: 4em; }
  .hub-index-header { margin-bottom: 3em; text-align: center; }
  .hub-index-title { font-family: 'Playfair Display', serif; font-size: 1.8em; font-weight: 700; color: #2C1F0E; margin: 0 0 1em; }
  .hub-index-meta { display: flex; align-items: center; justify-content: center; gap: 1em; }
  .hub-index-line { height: 1px; width: 3em; background: rgba(184,149,42,0.25); }
  .hub-index-label { font-family: 'Libre Caslon Text', serif; font-size: 0.52em; letter-spacing: 0.2em; text-transform: uppercase; color: #7A6840; white-space: nowrap; }

  /* Cards grid */
  .hub-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2em;
  }

  .hub-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2.5em 2em;
    background: rgba(245,239,224,0.3);
    border: 1px solid rgba(184,149,42,0.22);
    text-decoration: none;
    color: inherit;
  }
  .hub-card:hover { text-decoration: none; color: inherit; }

  .hub-card-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5em;
  }
  .hub-card-icon .material-symbols-outlined { font-size: 2.2em !important; color: #B8952A; }
  .hub-card-icon--tema .material-symbols-outlined { color: #8B3A3A; }
  .hub-card--tema { border-color: rgba(139,58,58,0.2); }
  .hub-card--tema:hover { border-color: rgba(139,58,58,0.5); }

  .hub-card-title { font-family: 'Playfair Display', serif; font-size: 1.1em; font-weight: 700; color: #2C1F0E; margin: 0 0 0.75em; line-height: 1.25; transition: color 0.2s; }
  .hub-card:hover .hub-card-title { color: #B8952A; }

  .hub-card-desc { font-family: 'EB Garamond', serif; font-size: 0.9em; color: #7A6840; line-height: 1.65; flex: 1; margin: 0 0 1.5em; }

  .hub-card-cta { font-family: 'Libre Caslon Text', serif; font-size: 0.5em; letter-spacing: 0.2em; text-transform: uppercase; color: #2C1F0E; border-bottom: 1px solid #B8952A; padding-bottom: 0.1em; transition: color 0.2s; margin-top: auto; }
  .hub-card:hover .hub-card-cta { color: #B8952A; }

  /* CTA section */
  .hub-cta-section { background: #F5EFE0; padding: 4em 3em; text-align: center; }
  .hub-cta-title { font-family: 'Playfair Display', serif; font-size: 1.6em; font-weight: 700; font-style: italic; color: #2C1F0E; margin: 0 0 0.75em; }
  .hub-cta-desc { font-family: 'EB Garamond', serif; font-size: 1em; color: #7A6840; line-height: 1.7; max-width: 500px; margin: 0 auto 2em; }
  .hub-cta-desc a { color: #8B6914; text-decoration: none; }
  .hub-cta-desc a:hover { text-decoration: underline; }
  .hub-cta-btn {
    display: inline-block;
    background: #B8952A;
    color: #fff;
    font-family: 'Libre Caslon Text', serif;
    font-size: 0.55em;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 1em 2.5em;
    text-decoration: none;
    transition: background 0.2s;
  }
  .hub-cta-btn:hover { background: #8B6914; text-decoration: none; color: #fff; }

  /* Responsive */
  @media (max-width: 860px) {
    .hub-cards-grid { grid-template-columns: repeat(2, 1fr); }
    .hub-hero { height: 480px; }
  }
  @media (max-width: 560px) {
    .hub-cards-grid { grid-template-columns: 1fr; }
    .hub-hero { height: 380px; }
    .hub-hero-title { font-size: 1.9em; }
  }
</style>
