---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import headerImg from '../assets/blog/hipnosis-ojo-mistico.jpg';

const allPosts = await getCollection('blog');

const ARTICULOS_HIPNOSIS = allPosts
  .filter(p => p.data.expositor === 'hipnosis')
  .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

const ARTICULOS_ICONS = [
  'psychology', 'history_edu', 'science', 'person', 'compare_arrows', 'help_outline',
];

const SITEURL = 'https://www.regresionvidaspasadas.com';
const HUB_URL = `${SITEURL}/hipnosis/`;

const hipnosisSchema = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${HUB_URL}#collectionpage`,
    name: 'Hipnosis Clínica',
    description: 'Portal temático sobre hipnosis clínica: historia, técnicas, mitos, Milton Erickson y su relación con la regresión terapéutica.',
    url: HUB_URL,
    inLanguage: 'es',
    publisher: { '@id': `${SITEURL}/#organization` },
    hasPart: ARTICULOS_HIPNOSIS.map(p => ({
      '@type': 'Article',
      '@id': `${SITEURL}/blog/${p.id}/#article`,
      name: p.data.title,
      url: `${SITEURL}/blog/${p.id}/`,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITEURL },
      { '@type': 'ListItem', position: 2, name: 'Hipnosis', item: HUB_URL },
    ],
  },
]);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead
      title="Hipnosis: qué es, su historia y cómo funciona"
      description="Todo sobre la hipnosis: sus orígenes chamánicos y con Mesmer, Milton Erickson y la hipnosis clínica moderna, la diferencia entre hipnosis de espectáculo y terapéutica, mitos, realidades y su relación con la regresión."
    />
    <script type="application/ld+json" set:html={hipnosisSchema}></script>
    <style>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        font-family: 'Material Symbols Outlined';
        line-height: 1;
        display: inline-block;
        vertical-align: middle;
        color: #4A6B8A;
      }
      .ornament { height: 1px; background: linear-gradient(90deg, transparent, #B8952A, transparent); width: 100%; margin: 2.5em 0; }
      .card-hover { transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.4s ease, border-color 0.3s; }
      .card-hover:hover { transform: translateY(-4px); box-shadow: 0 20px 25px -5px rgba(44,31,14,0.07); border-color: rgba(74,107,138,0.55); }
    </style>
  </head>
  <body>
    <Header />

    <!-- Hero 614px -->
    <section class="hub-hero">
      <div class="hub-hero-bg">
        <Image src={headerImg} alt="Hipnosis clínica y estados alterados de conciencia" width={1400} height={614} class="hub-hero-img" />
        <div class="hub-hero-overlay"></div>
      </div>
      <div class="hub-hero-content">
        <span class="hub-hero-eyebrow">Exploración Académica</span>
        <h1 class="hub-hero-title">Hipnosis Clínica</h1>
        <p class="hub-hero-desc">No es sueño, no es control mental y no comenzó con Mesmer. Una guía completa desde los orígenes ancestrales hasta la práctica terapéutica actual.</p>
        <div class="hub-hero-line"></div>
      </div>
    </section>

    <main class="hub-main">

      <section class="hub-index-section">
        <div class="hub-index-header">
          <h2 class="hub-index-title">Índice Editorial</h2>
          <div class="hub-index-meta">
            <div class="hub-index-line"></div>
            <span class="hub-index-label">Artículos sobre hipnosis</span>
            <div class="hub-index-line"></div>
          </div>
        </div>

        <div class="hub-cards-grid">
          {ARTICULOS_HIPNOSIS.map((art, i) => (
            <a href={`/blog/${art.id}/`} class="hub-card card-hover">
              <div class="hub-card-icon">
                <span class="material-symbols-outlined">{ARTICULOS_ICONS[i] ?? 'psychology'}</span>
              </div>
              <h3 class="hub-card-title">{art.data.title}</h3>
              {art.data.description && <p class="hub-card-desc">{art.data.description}</p>}
              <span class="hub-card-cta">Leer artículo</span>
            </a>
          ))}
        </div>
      </section>

      <!-- CTA -->
      <section class="hub-cta-section">
        <div class="ornament"></div>
        <h3 class="hub-cta-title">¿Quieres explorar la hipnosis?</h3>
        <p class="hub-cta-desc">
          La hipnosis es la base de la terapia de regresión. Conoce el trabajo de
          <a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener">Juan Pablo Loaiza</a>,
          terapeuta certificado en RVP e hipnosis clínica.
        </p>
        <a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener" class="hub-cta-btn">Conocer al especialista</a>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style>
  .hub-hero { position: relative; width: 100%; height: 614px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .hub-hero-bg { position: absolute; inset: 0; }
  .hub-hero-img { width: 100%; height: 100%; object-fit: cover; object-position: center; max-width: none; border-radius: 0; display: block; }
  .hub-hero-overlay { position: absolute; inset: 0; background: rgba(20,40,60,0.5); }
  .hub-hero-content { position: relative; z-index: 10; text-align: center; padding: 0 2em; max-width: 700px; }
  .hub-hero-eyebrow { font-family: 'Libre Caslon Text', serif; color: rgba(255,255,255,0.9); letter-spacing: 0.28em; font-size: 0.55em; text-transform: uppercase; display: block; margin-bottom: 1em; }
  .hub-hero-title { font-family: 'Playfair Display', serif; font-size: clamp(2em, 6vw, 4em); font-weight: 700; color: #fff; margin: 0 0 0.6em; line-height: 1.1; }
  .hub-hero-desc { font-family: 'EB Garamond', serif; font-size: 1.1em; font-style: italic; color: rgba(255,255,255,0.8); max-width: 520px; margin: 0 auto 1.5em; line-height: 1.65; }
  .hub-hero-line { width: 6em; height: 1px; background: #B8952A; margin: 0 auto; }

  .hub-main { max-width: 1100px; margin: 0 auto; padding: 5em 2em 6em; }

  .hub-index-section { margin-bottom: 4em; }
  .hub-index-header { margin-bottom: 3em; text-align: center; }
  .hub-index-title { font-family: 'Playfair Display', serif; font-size: 1.8em; font-weight: 700; color: #2C1F0E; margin: 0 0 1em; }
  .hub-index-meta { display: flex; align-items: center; justify-content: center; gap: 1em; }
  .hub-index-line { height: 1px; width: 3em; background: rgba(184,149,42,0.25); }
  .hub-index-label { font-family: 'Libre Caslon Text', serif; font-size: 0.52em; letter-spacing: 0.2em; text-transform: uppercase; color: #7A6840; white-space: nowrap; }

  .hub-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2em;
  }

  .hub-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2.5em 2em;
    background: rgba(245,239,224,0.3);
    border: 1px solid rgba(74,107,138,0.22);
    text-decoration: none;
    color: inherit;
  }
  .hub-card:hover { text-decoration: none; color: inherit; }

  .hub-card-icon { width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5em; }
  .hub-card-icon .material-symbols-outlined { font-size: 2.2em !important; }

  .hub-card-title { font-family: 'Playfair Display', serif; font-size: 1.1em; font-weight: 700; color: #2C1F0E; margin: 0 0 0.75em; line-height: 1.25; transition: color 0.2s; }
  .hub-card:hover .hub-card-title { color: #4A6B8A; }

  .hub-card-desc { font-family: 'EB Garamond', serif; font-size: 0.9em; color: #7A6840; line-height: 1.65; flex: 1; margin: 0 0 1.5em; }

  .hub-card-cta { font-family: 'Libre Caslon Text', serif; font-size: 0.5em; letter-spacing: 0.2em; text-transform: uppercase; color: #2C1F0E; border-bottom: 1px solid #4A6B8A; padding-bottom: 0.1em; transition: color 0.2s; margin-top: auto; }
  .hub-card:hover .hub-card-cta { color: #4A6B8A; }

  .hub-cta-section { background: #F5EFE0; padding: 4em 3em; text-align: center; }
  .hub-cta-title { font-family: 'Playfair Display', serif; font-size: 1.6em; font-weight: 700; font-style: italic; color: #2C1F0E; margin: 0 0 0.75em; }
  .hub-cta-desc { font-family: 'EB Garamond', serif; font-size: 1em; color: #7A6840; line-height: 1.7; max-width: 500px; margin: 0 auto 2em; }
  .hub-cta-desc a { color: #8B6914; text-decoration: none; }
  .hub-cta-desc a:hover { text-decoration: underline; }
  .hub-cta-btn {
    display: inline-block;
    background: #B8952A;
    color: #fff;
    font-family: 'Libre Caslon Text', serif;
    font-size: 0.55em;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 1em 2.5em;
    text-decoration: none;
    transition: background 0.2s;
  }
  .hub-cta-btn:hover { background: #8B6914; text-decoration: none; color: #fff; }

  @media (max-width: 860px) { .hub-cards-grid { grid-template-columns: repeat(2, 1fr); } .hub-hero { height: 480px; } }
  @media (max-width: 560px) { .hub-cards-grid { grid-template-columns: 1fr; } .hub-hero { height: 380px; } .hub-hero-title { font-size: 1.9em; } }
</style>
