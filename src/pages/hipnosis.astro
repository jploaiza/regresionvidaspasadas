---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import headerImg from '../assets/blog/hipnosis-ojo-mistico.jpg';

const allPosts = await getCollection('blog');

const ARTICULOS_HIPNOSIS = allPosts
  .filter(p => p.data.expositor === 'hipnosis')
  .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

const SITEURL = 'https://www.regresionvidaspasadas.com';
const HUB_URL = `${SITEURL}/hipnosis/`;

const hipnosisSchema = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${HUB_URL}#collectionpage`,
    name: 'Hipnosis Clínica',
    description: 'Portal temático sobre hipnosis clínica: historia, técnicas, mitos, Milton Erickson y su relación con la regresión terapéutica.',
    url: HUB_URL,
    inLanguage: 'es',
    publisher: { '@id': `${SITEURL}/#organization` },
    hasPart: ARTICULOS_HIPNOSIS.map(p => ({
      '@type': 'Article',
      '@id': `${SITEURL}/blog/${p.id}/#article`,
      name: p.data.title,
      url: `${SITEURL}/blog/${p.id}/`,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITEURL },
      { '@type': 'ListItem', position: 2, name: 'Hipnosis', item: HUB_URL },
    ],
  },
]);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead
      title="Hipnosis: qué es, su historia y cómo funciona"
      description="Todo sobre la hipnosis: sus orígenes chamánicos y con Mesmer, Milton Erickson y la hipnosis clínica moderna, la diferencia entre hipnosis de espectáculo y terapéutica, mitos, realidades y su relación con la regresión."
    />
    <script type="application/ld+json" set:html={hipnosisSchema}></script>
  </head>
  <body>
    <Header />

    <div class="page-hero">
      <Image src={headerImg} alt="Hipnosis clínica y estados alterados de conciencia" width={1200} height={420} class="hero-img" />
      <div class="hero-overlay">
        <span class="hero-eyebrow">Disciplina · Hipnosis</span>
        <h1>Hipnosis Clínica</h1>
        <p class="hero-desc">No es sueño, no es control mental y no comenzó con Mesmer. Una guía completa desde los orígenes ancestrales hasta la práctica clínica actual.</p>
      </div>
    </div>

    <main class="hub-main">

      <section class="cards-section">
        <div class="section-eyebrow">
          <span class="eyebrow-ornament">✦</span>
          <span class="eyebrow-text">Artículos sobre hipnosis</span>
        </div>
        <div class="cards-grid">
          {ARTICULOS_HIPNOSIS.map((art, i) => (
            <a href={`/blog/${art.id}/`} class="hub-card">
              <span class="card-num">0{i + 1}</span>
              <div class="card-body">
                <h3 class="card-title">{art.data.title}</h3>
                {art.data.description && <p class="card-desc">{art.data.description}</p>}
                <span class="card-cta">Leer artículo →</span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <div class="hub-cta">
        <span class="hub-cta-label">¿Quieres explorar la hipnosis en profundidad?</span>
        <p>La hipnosis es la base de la terapia de regresión. Conoce cómo trabaja el especialista <a href="/expositores">Juan Pablo Loaiza</a> o explora la <a href="/srt">Terapia de Liberación Espiritual</a>.</p>
        <a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener" class="hub-cta-btn">juanpabloloaiza.com →</a>
      </div>

    </main>
    <Footer />
  </body>
</html>

<style>
  /* ——— Hero ——— */
  .page-hero { position: relative; width: 100%; height: 420px; overflow: hidden; }
  .hero-img { width: 100%; height: 420px; object-fit: cover; filter: sepia(10%) brightness(0.60) hue-rotate(190deg); display: block; border-radius: 0; }
  .hero-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 3em 2em;
    text-align: center;
    background: linear-gradient(to bottom, rgba(20,40,60,0.1) 0%, rgba(20,40,60,0.72) 100%);
  }
  .hero-eyebrow { font-family: 'Cinzel', serif; font-size: 0.62em; letter-spacing: 0.22em; text-transform: uppercase; color: #7AA8C8; margin-bottom: 0.75em; }
  .hero-overlay h1 { font-family: 'Cinzel', serif; font-size: 2.6em; font-weight: 400; color: #FDFAF4; margin-bottom: 0.4em; text-shadow: 0 2px 12px rgba(0,0,0,0.5); }
  .hero-desc { color: rgba(253,250,244,0.8); font-size: 0.95em; max-width: 540px; line-height: 1.65; margin: 0; }

  /* ——— Main ——— */
  .hub-main { max-width: 1080px; margin: 0 auto; padding: 4em 1.5em 5em; }

  /* ——— Eyebrow ——— */
  .section-eyebrow { display: flex; align-items: center; gap: 0.75em; margin-bottom: 1.5em; }
  .eyebrow-ornament { color: #D4AF6A; font-size: 0.65em; }
  .eyebrow-text { font-family: 'Cinzel', serif; font-size: 0.68em; letter-spacing: 0.22em; text-transform: uppercase; color: #A89060; }

  /* ——— Cards ——— */
  .cards-section { margin-bottom: 3.5em; }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25em;
  }

  .hub-card {
    display: flex;
    flex-direction: column;
    gap: 0.75em;
    padding: 1.75em 1.5em;
    background: #F5EFE0;
    border: 1px solid rgba(184,149,42,0.15);
    border-top: 3px solid #4A6B8A;
    border-radius: 0 0 6px 6px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .hub-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(20,40,60,0.1); }

  .card-num { font-family: 'Cinzel', serif; font-size: 1.4em; color: rgba(74,107,138,0.3); line-height: 1; }

  .card-body { display: flex; flex-direction: column; gap: 0.4em; flex: 1; }

  .card-title { font-family: 'Cinzel', serif; font-size: 0.88em; font-weight: 400; color: #2C1F0E; line-height: 1.3; margin: 0; }

  .card-desc {
    font-size: 0.82em;
    color: #7A6840;
    line-height: 1.6;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-cta { font-family: 'Cinzel', serif; font-size: 0.62em; letter-spacing: 0.1em; color: #4A6B8A; margin-top: 0.5em; }

  /* ——— Hub CTA ——— */
  .hub-cta {
    background: #F5EFE0;
    border: 1px solid rgba(184,149,42,0.2);
    border-radius: 8px;
    padding: 2.5em 2em;
    text-align: center;
    margin-top: 2em;
  }
  .hub-cta-label { display: block; font-family: 'Cinzel', serif; font-size: 0.68em; letter-spacing: 0.18em; text-transform: uppercase; color: #A89060; margin-bottom: 0.75em; }
  .hub-cta p { font-size: 0.9em; color: #5A4830; line-height: 1.7; margin-bottom: 1.5em; }
  .hub-cta a { color: #4A6B8A; text-decoration: none; }
  .hub-cta a:hover { text-decoration: underline; }
  .hub-cta-btn {
    display: inline-block;
    font-family: 'Cinzel', serif;
    font-size: 0.72em;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: #B8952A;
    color: #FDFAF4 !important;
    text-decoration: none !important;
    border-radius: 4px;
    padding: 0.85em 2em;
    transition: background 0.2s;
  }
  .hub-cta-btn:hover { background: #9A7A20 !important; }

  @media (max-width: 860px) { .cards-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) {
    .hero-overlay h1 { font-size: 1.9em; }
    .page-hero, .hero-img { height: 320px; }
    .cards-grid { grid-template-columns: 1fr; }
  }
</style>
