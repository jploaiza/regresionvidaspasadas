---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import headerImg from '../assets/blog/hipnosis-ojo-mistico.jpg';

const allPosts = await getCollection('blog');

const ARTICULOS_HIPNOSIS = allPosts
  .filter(p => p.data.expositor === 'hipnosis')
  .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

const SITEURL = 'https://www.regresionvidaspasadas.com';
const HUB_URL = `${SITEURL}/hipnosis/`;

const hipnosisSchema = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    '@id': `${HUB_URL}#collectionpage`,
    name: 'Hipnosis Clínica',
    description: 'Portal temático sobre hipnosis clínica: historia, técnicas, mitos, Milton Erickson y su relación con la regresión terapéutica.',
    url: HUB_URL,
    inLanguage: 'es',
    publisher: { '@id': `${SITEURL}/#organization` },
    hasPart: ARTICULOS_HIPNOSIS.map(p => ({
      '@type': 'Article',
      '@id': `${SITEURL}/blog/${p.id}/#article`,
      name: p.data.title,
      url: `${SITEURL}/blog/${p.id}/`,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITEURL },
      { '@type': 'ListItem', position: 2, name: 'Hipnosis', item: HUB_URL },
    ],
  },
]);
---

<!doctype html>
<html lang="es">
  <head>
    <BaseHead
      title="Hipnosis: qué es, su historia y cómo funciona"
      description="Todo sobre la hipnosis: sus orígenes chamánicos y con Mesmer, Milton Erickson y la hipnosis clínica moderna, la diferencia entre hipnosis de espectáculo y terapéutica, mitos, realidades y su relación con la regresión."
    />
    <script type="application/ld+json" set:html={hipnosisSchema}></script>
  </head>
  <body>
    <Header />

    <div class="page-hero">
      <Image src={headerImg} alt="Hipnosis clínica y estados alterados de conciencia" width={1200} height={320} class="hero-img" />
      <div class="hero-overlay">
        <span class="ornament">✦</span>
        <h1>Hipnosis</h1>
        <p>No es sueño, no es control mental y no comenzó con Mesmer. Una guía completa desde los orígenes ancestrales hasta la práctica clínica actual.</p>
      </div>
    </div>

    <main class="page-wrap">
      <div class="intro-grid">
        <div class="intro-card">
          <span class="intro-icon">🌀</span>
          <h3>¿Qué es realmente?</h3>
          <p>Un estado de atención focalizada y sugestibilidad aumentada. Sin pérdida de conciencia, sin sueño, sin pérdida de control.</p>
        </div>
        <div class="intro-card">
          <span class="intro-icon">🥁</span>
          <h3>Más antigua que Mesmer</h3>
          <p>Los chamanes siberianos, los templos griegos de Asclepio y los sacerdotes egipcios usaban el trance curativo miles de años antes.</p>
        </div>
        <div class="intro-card">
          <span class="intro-icon">🧠</span>
          <h3>Medible en el cerebro</h3>
          <p>La neuroimagen muestra cambios reales en la conectividad cerebral durante el trance. No es imaginación — es fisiología.</p>
        </div>
      </div>

      <section class="articulos-section">
        <h2 class="section-title">Artículos sobre hipnosis</h2>
        <ul class="articulos-lista">
          {ARTICULOS_HIPNOSIS.map(art => (
            <li>
              <a href={`/blog/${art.id}/`} class="articulo-card">
                <div class="art-content">
                  <span class="art-title">{art.data.title}</span>
                  <span class="art-desc">{art.data.description}</span>
                </div>
                <span class="art-arrow">→</span>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <div class="cta-section">
        <p class="cta-text">
          La hipnosis es la puerta de acceso a la regresión a vidas pasadas.
          Si quieres saber más sobre cómo funciona el proceso completo,
          visita la sección de <a href="/expositores">grandes expositores</a> o
          <a href="/srt">Terapia de Liberación Espiritual</a>.
        </p>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .page-hero {
    position: relative;
    width: 100%;
    height: 320px;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: 320px;
    object-fit: cover;
    filter: sepia(10%) brightness(0.65) hue-rotate(190deg);
    display: block;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2em;
    background: linear-gradient(to bottom, rgba(44,31,14,0.2) 0%, rgba(44,31,14,0.6) 100%);
  }

  .hero-overlay .ornament {
    color: #4A6B8A;
    font-size: 0.85em;
    letter-spacing: 0.5em;
    margin-bottom: 0.75em;
  }

  .hero-overlay h1 {
    font-family: 'Cinzel', serif;
    font-size: 3em;
    font-weight: 400;
    color: #FDFAF4;
    margin-bottom: 0.4em;
    text-shadow: 0 2px 8px rgba(0,0,0,0.5);
  }

  .hero-overlay p {
    color: #EDE5D0;
    font-size: 0.95em;
    max-width: 520px;
    line-height: 1.65;
  }

  .page-wrap {
    max-width: 800px;
    margin: 0 auto;
    padding: 2.5em 1.5em 4em;
  }

  .ornament {
    display: block;
    color: #4A6B8A;
    font-size: 0.9em;
    letter-spacing: 0.4em;
    margin-bottom: 1em;
  }

  .divider {
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #4A6B8A, transparent);
    margin: 0 auto;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1em;
    margin: 2.5em 0;
  }

  .intro-card {
    background: #F5EFE0;
    border-radius: 8px;
    padding: 1.25em 1em;
    text-align: center;
    border-top: 3px solid rgba(74, 107, 138, 0.25);
  }

  .intro-icon {
    display: block;
    font-size: 1.6em;
    margin-bottom: 0.5em;
  }

  .intro-card h3 {
    font-family: 'Cinzel', serif;
    font-size: 0.75em;
    letter-spacing: 0.08em;
    color: #2C1F0E;
    margin-bottom: 0.5em;
  }

  .intro-card p {
    font-size: 0.85em;
    color: #5A4830;
    line-height: 1.6;
    margin: 0;
  }

  .section-title {
    font-family: 'Cinzel', serif;
    font-size: 0.75em;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #4A6B8A;
    margin: 2.5em 0 1em;
  }

  .articulos-lista {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }

  .articulo-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1em;
    padding: 1em 1.25em;
    background: #F5EFE0;
    border-radius: 6px;
    text-decoration: none;
    border: 1px solid transparent;
    transition: border-color 0.2s, background 0.2s;
  }

  .articulo-card:hover {
    border-color: rgba(74, 107, 138, 0.3);
    background: #EDE5D0;
  }

  .art-content {
    display: flex;
    flex-direction: column;
    gap: 0.25em;
  }

  .art-title {
    font-size: 0.95em;
    color: #2C1F0E;
    font-weight: 500;
  }

  .art-desc {
    font-size: 0.82em;
    color: #7A6840;
    line-height: 1.4;
  }

  .art-arrow { color: #4A6B8A; flex-shrink: 0; }

  .cta-section {
    margin-top: 3em;
    padding: 1.5em;
    background: #F5EFE0;
    border-radius: 8px;
    border-left: 3px solid rgba(74, 107, 138, 0.35);
  }

  .cta-text {
    color: #5A4830;
    line-height: 1.7;
    margin: 0;
    font-size: 0.95em;
  }

  .cta-text a {
    color: #4A6B8A;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 600px) {
    .intro-grid { grid-template-columns: 1fr; }
    .page-header h1 { font-size: 2em; }
  }
</style>
