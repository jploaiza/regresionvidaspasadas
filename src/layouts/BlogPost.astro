---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import SearchModal from '../components/SearchModal.astro';
import { CATEGORY, SLUG_IMG } from '../consts';

// All available images — keyed by filename without extension
import imgVelasSeance    from '../assets/blog/srt-velas-seance.jpg';
import imgVelaOscuridad  from '../assets/blog/srt-vela-oscuridad.jpg';
import imgManosLuz       from '../assets/blog/srt-manos-luz.jpg';
import imgOjoMistico     from '../assets/blog/hipnosis-ojo-mistico.jpg';
import imgMeditacion     from '../assets/blog/rvp-meditacion.jpg';
import imgDefault        from '../assets/blog/hero-meditacion-amanecer.jpg';
import imgCosmos         from '../assets/blog/cosmos-estrellas.jpg';
import imgHumoOscuro     from '../assets/blog/srt-humo-oscuro.jpg';
import imgTerapia        from '../assets/blog/terapia-sesion.jpg';
import imgPortalLuz      from '../assets/blog/portal-luz.jpg';
import imgNinos          from '../assets/blog/ninos-naturaleza.jpg';
import imgMeditGrupal    from '../assets/blog/meditacion-grupal.jpg';
import imgRitualFuego    from '../assets/blog/ritual-fuego.jpg';
import imgSilueta        from '../assets/blog/silueta-espiritual.jpg';
import imgLibros         from '../assets/blog/libros-vintage.jpg';
import imgQueEs          from '../assets/blog/que-es-regresion.jpg';
import imgBeneficios     from '../assets/blog/beneficios-regresion.jpg';
import imgSesion         from '../assets/blog/sesion-regresion.jpg';

import type { ImageMetadata } from 'astro';

const IMG_REGISTRY: Record<string, ImageMetadata> = {
  'srt-velas-seance':    imgVelasSeance,
  'srt-vela-oscuridad':  imgVelaOscuridad,
  'srt-manos-luz':       imgManosLuz,
  'hipnosis-ojo-mistico': imgOjoMistico,
  'rvp-meditacion':      imgMeditacion,
  'hero-meditacion-amanecer': imgDefault,
  'cosmos-estrellas':    imgCosmos,
  'srt-humo-oscuro':     imgHumoOscuro,
  'terapia-sesion':      imgTerapia,
  'portal-luz':          imgPortalLuz,
  'ninos-naturaleza':    imgNinos,
  'meditacion-grupal':   imgMeditGrupal,
  'ritual-fuego':        imgRitualFuego,
  'silueta-espiritual':  imgSilueta,
  'libros-vintage':      imgLibros,
  'que-es-regresion':    imgQueEs,
  'beneficios-regresion': imgBeneficios,
  'sesion-regresion':    imgSesion,
};

const EXPOSITOR_IMG: Record<string, ImageMetadata> = {
  'carl-wickland':   imgVelasSeance,
  'william-baldwin': imgManosLuz,
  'edith-fiore':     imgMeditacion,
  'alan-sanderson':  imgMeditacion,
  'srt':             imgVelaOscuridad,
  'hipnosis':        imgOjoMistico,
};

interface Props extends CollectionEntry<'blog'>['data'] {
  readingTime?: number;
  postId?: string;
}

const { title, description, pubDate, updatedDate, heroImage, expositor, readingTime, postId } = Astro.props;

function resolveImage(): ImageMetadata {
  if (heroImage) return heroImage;
  // Slug-specific mapping
  if (postId && SLUG_IMG[postId]) {
    const key = SLUG_IMG[postId];
    if (IMG_REGISTRY[key]) return IMG_REGISTRY[key];
  }
  // Expositor fallback
  if (expositor && EXPOSITOR_IMG[expositor]) return EXPOSITOR_IMG[expositor];
  return imgDefault;
}

const displayImage = resolveImage();
const cat = expositor ? CATEGORY[expositor] : undefined;

const siteUrl = Astro.site ?? 'https://www.regresionvidaspasadas.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const ogImage = new URL(displayImage.src, siteUrl);

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
  image: ogImage.href,
  url: canonicalUrl.href,
  wordCount: readingTime ? readingTime * 200 : undefined,
  author: {
    '@type': 'Person',
    name: 'Juan Pablo Loaiza',
    url: 'https://www.juanpabloloaiza.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Regresión a Vidas Pasadas',
    url: siteUrl.toString(),
  },
});
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} image={displayImage} />
		<script type="application/ld+json" set:html={jsonLd}></script>
		<style>
			/* ——— Article hero (editorial overlay) ——— */
			.article-hero {
				position: relative;
				width: 100%;
				height: 480px;
				overflow: hidden;
			}

			.article-hero-img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: center 35%;
				display: block;
				filter: brightness(0.55) saturate(0.85);
			}

			.article-hero-overlay {
				position: absolute;
				inset: 0;
				background: linear-gradient(
					to bottom,
					rgba(20, 10, 5, 0.05) 0%,
					rgba(20, 10, 5, 0.1) 35%,
					rgba(20, 10, 5, 0.65) 60%,
					rgba(20, 10, 5, 0.90) 100%
				);
				display: flex;
				flex-direction: column;
				justify-content: flex-end;
				padding: 0;
			}

			.article-hero-content {
				max-width: 760px;
				margin: 0 auto;
				width: 100%;
				padding: 0 1.75em 2.5em;
			}

			.article-hero-badge {
				display: inline-block;
				font-family: 'Cinzel', serif;
				font-size: 0.62em;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				padding: 0.3em 0.8em;
				border-radius: 3px;
				border: 1px solid rgba(255,255,255,0.35);
				color: rgba(255,255,255,0.85);
				margin-bottom: 0.85em;
			}

			.article-hero h1 {
				font-family: 'Crimson Text', serif;
				font-size: 2.8em;
				font-weight: 400;
				color: #FDFAF4;
				line-height: 1.15;
				margin-bottom: 0.55em;
				text-shadow: 0 2px 12px rgba(0,0,0,0.4);
			}

			.article-hero-desc {
				font-family: 'Crimson Text', serif;
				font-size: 1.1em;
				color: rgba(253, 250, 244, 0.78);
				line-height: 1.55;
				margin-bottom: 1.1em;
				font-style: italic;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.article-hero-meta {
				display: flex;
				align-items: center;
				gap: 1.25em;
				flex-wrap: wrap;
			}

			.article-meta-item {
				font-family: 'Cinzel', serif;
				font-size: 0.68em;
				letter-spacing: 0.1em;
				color: rgba(255, 255, 255, 0.6);
				display: flex;
				align-items: center;
				gap: 0.4em;
			}

			.article-meta-sep {
				color: rgba(255, 255, 255, 0.3);
				font-size: 0.8em;
			}

			/* ——— Article body ——— */
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2.5em 1em 3.5em;
				color: var(--text, #2C1F0E);
			}

			.prose :global(h2) {
				font-family: 'Cinzel', serif;
				font-size: 1.15em;
				font-weight: 400;
				color: #2C1F0E;
				margin: 2em 0 0.75em;
				letter-spacing: 0.03em;
			}

			.prose :global(h3) {
				font-family: 'Cinzel', serif;
				font-size: 0.95em;
				font-weight: 500;
				color: #4A3820;
				margin: 1.5em 0 0.5em;
				letter-spacing: 0.04em;
			}

			.prose :global(p) {
				font-size: 1.08em;
				line-height: 1.75;
				color: #3A2A10;
				margin-bottom: 1.25em;
			}

			.prose :global(strong) {
				color: #2C1F0E;
				font-weight: 600;
			}

			.prose :global(blockquote) {
				border-left: 3px solid rgba(184, 149, 42, 0.4);
				margin: 1.5em 0;
				padding: 0.75em 1.25em;
				background: #F5EFE0;
				border-radius: 0 5px 5px 0;
				font-style: italic;
				color: #5A4830;
			}

			.prose :global(ul), .prose :global(ol) {
				padding-left: 1.5em;
				margin-bottom: 1.25em;
			}

			.prose :global(li) {
				margin-bottom: 0.4em;
				line-height: 1.7;
				font-size: 1.05em;
				color: #3A2A10;
			}

			/* ——— Author card ——— */
			.author-card {
				margin-top: 3.5em;
				padding: 1.25em 1.5em;
				border-left: 3px solid rgba(184, 149, 42, 0.35);
				background: #F5EFE0;
				border-radius: 0 5px 5px 0;
			}

			.author-label {
				display: block;
				font-family: 'Cinzel', serif;
				font-size: 0.68em;
				letter-spacing: 0.15em;
				text-transform: uppercase;
				color: #A89060;
				margin-bottom: 0.6em;
			}

			.author-card p {
				font-size: 0.9em;
				color: #7A6840;
				line-height: 1.65;
				margin: 0;
			}

			.author-card a {
				color: #8B6914;
				text-decoration: none;
			}

			.author-card a:hover { text-decoration: underline; }

			@media (max-width: 600px) {
				.article-hero { height: 380px; }
				.article-hero h1 { font-size: 2em; }
				.article-hero-desc { display: none; }
			}
		</style>
	</head>

	<body>
		<Header />
		<SearchModal />
		<main>
			<article>
				<div class="article-hero">
					<Image
						width={1200}
						height={480}
						src={displayImage}
						alt={title}
						class="article-hero-img"
					/>
					<div class="article-hero-overlay">
						<div class="article-hero-content">
							{cat && (
								<span class="article-hero-badge" style={`border-color:${cat.color}80; color:${cat.color}; background:${cat.color}22`}>
									{cat.label}
								</span>
							)}
							<h1>{title}</h1>
							{description && <p class="article-hero-desc">{description}</p>}
							<div class="article-hero-meta">
								<span class="article-meta-item">
									<FormattedDate date={pubDate} />
								</span>
								{readingTime && (
									<>
										<span class="article-meta-sep">·</span>
										<span class="article-meta-item">{readingTime} min de lectura</span>
									</>
								)}
								{updatedDate && (
									<>
										<span class="article-meta-sep">·</span>
										<span class="article-meta-item">Actualizado: <FormattedDate date={updatedDate} /></span>
									</>
								)}
							</div>
						</div>
					</div>
				</div>

				<div class="prose">
					<slot />
					<div class="author-card">
						<span class="author-label">Sobre el autor</span>
						<p>
							<a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener">Juan Pablo Loaiza</a>
							es terapeuta de Regresión a Vidas Pasadas. Si quieres explorar este proceso, puedes conocer su trabajo en
							<a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener">juanpabloloaiza.com</a>.
						</p>
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
