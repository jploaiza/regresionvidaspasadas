---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import SearchModal from '../components/SearchModal.astro';
import { CATEGORY, SLUG_IMG } from '../consts';

// All available images — keyed by filename without extension
import imgVelasSeance    from '../assets/blog/srt-velas-seance.jpg';
import imgVelaOscuridad  from '../assets/blog/srt-vela-oscuridad.jpg';
import imgManosLuz       from '../assets/blog/srt-manos-luz.jpg';
import imgOjoMistico     from '../assets/blog/hipnosis-ojo-mistico.jpg';
import imgMeditacion     from '../assets/blog/rvp-meditacion.jpg';
import imgDefault        from '../assets/blog/hero-meditacion-amanecer.jpg';
import imgCosmos         from '../assets/blog/cosmos-estrellas.jpg';
import imgHumoOscuro     from '../assets/blog/srt-humo-oscuro.jpg';
import imgTerapia        from '../assets/blog/terapia-sesion.jpg';
import imgPortalLuz      from '../assets/blog/portal-luz.jpg';
import imgNinos          from '../assets/blog/ninos-naturaleza.jpg';
import imgMeditGrupal    from '../assets/blog/meditacion-grupal.jpg';
import imgRitualFuego    from '../assets/blog/ritual-fuego.jpg';
import imgSilueta        from '../assets/blog/silueta-espiritual.jpg';
import imgLibros         from '../assets/blog/libros-vintage.jpg';
import imgQueEs          from '../assets/blog/que-es-regresion.jpg';
import imgBeneficios     from '../assets/blog/beneficios-regresion.jpg';
import imgSesion         from '../assets/blog/sesion-regresion.jpg';

import type { ImageMetadata } from 'astro';

const IMG_REGISTRY: Record<string, ImageMetadata> = {
  'srt-velas-seance':    imgVelasSeance,
  'srt-vela-oscuridad':  imgVelaOscuridad,
  'srt-manos-luz':       imgManosLuz,
  'hipnosis-ojo-mistico': imgOjoMistico,
  'rvp-meditacion':      imgMeditacion,
  'hero-meditacion-amanecer': imgDefault,
  'cosmos-estrellas':    imgCosmos,
  'srt-humo-oscuro':     imgHumoOscuro,
  'terapia-sesion':      imgTerapia,
  'portal-luz':          imgPortalLuz,
  'ninos-naturaleza':    imgNinos,
  'meditacion-grupal':   imgMeditGrupal,
  'ritual-fuego':        imgRitualFuego,
  'silueta-espiritual':  imgSilueta,
  'libros-vintage':      imgLibros,
  'que-es-regresion':    imgQueEs,
  'beneficios-regresion': imgBeneficios,
  'sesion-regresion':    imgSesion,
};

const EXPOSITOR_IMG: Record<string, ImageMetadata> = {
  'carl-wickland':   imgVelasSeance,
  'william-baldwin': imgManosLuz,
  'edith-fiore':     imgMeditacion,
  'alan-sanderson':  imgMeditacion,
  'srt':             imgVelaOscuridad,
  'hipnosis':        imgOjoMistico,
};

interface Props extends CollectionEntry<'blog'>['data'] {
  readingTime?: number;
  postId?: string;
  relatedPosts?: CollectionEntry<'blog'>[];
}

const { title, description, pubDate, updatedDate, heroImage, expositor, readingTime, postId, relatedPosts } = Astro.props;

function resolveImage(): ImageMetadata {
  if (heroImage) return heroImage;
  // Slug-specific mapping
  if (postId && SLUG_IMG[postId]) {
    const key = SLUG_IMG[postId];
    if (IMG_REGISTRY[key]) return IMG_REGISTRY[key];
  }
  // Expositor fallback
  if (expositor && EXPOSITOR_IMG[expositor]) return EXPOSITOR_IMG[expositor];
  return imgDefault;
}

const displayImage = resolveImage();
const cat = expositor ? CATEGORY[expositor] : undefined;

const siteUrl = Astro.site ?? 'https://www.regresionvidaspasadas.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const ogImage = new URL(displayImage.src, siteUrl);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${canonicalUrl.href}#article`,
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
  image: ogImage.href,
  url: canonicalUrl.href,
  inLanguage: 'es',
  ...(readingTime ? { wordCount: readingTime * 200 } : {}),
  author: {
    '@type': 'Person',
    '@id': 'https://www.juanpabloloaiza.com/#person',
    name: 'Juan Pablo Loaiza',
    url: 'https://www.juanpabloloaiza.com',
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${siteUrl}/#organization`,
    name: 'Regresión a Vidas Pasadas',
    url: siteUrl.toString(),
  },
  isPartOf: { '@id': `${siteUrl}/#organization` },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl.toString() },
    { '@type': 'ListItem', position: 2, name: 'Artículos', item: `${siteUrl}/blog/` },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl.href },
  ],
};

const medicalWebPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalWebPage',
  '@id': `${canonicalUrl.href}#medicalpage`,
  name: title,
  url: canonicalUrl.href,
  description,
  inLanguage: 'es',
  medicalAudience: [
    { '@type': 'MedicalAudience', audienceType: 'Patient' },
    { '@type': 'MedicalAudience', audienceType: 'Caregiver' },
  ],
  about: {
    '@type': 'MedicalTherapy',
    name: 'Regresión a Vidas Pasadas',
    alternateName: ['RVP', 'Past Life Regression', 'Terapia de Regresión'],
  },
  author: { '@id': 'https://www.juanpabloloaiza.com/#person' },
  publisher: { '@id': `${siteUrl}/#organization` },
};

const jsonLd = JSON.stringify([articleSchema, breadcrumbSchema, medicalWebPageSchema]);
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} image={displayImage} ogType="article" />
		<script type="application/ld+json" set:html={jsonLd}></script>
		<style>
			/* ——— Article hero (editorial overlay) ——— */
			.article-hero {
				position: relative;
				width: 100%;
				height: 480px;
				overflow: hidden;
			}

			.article-hero-img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: center 35%;
				display: block;
				filter: brightness(0.55) saturate(0.85);
				border-radius: 0;
				max-width: none;
			}

			.article-hero-overlay {
				position: absolute;
				inset: 0;
				background: linear-gradient(
					to bottom,
					rgba(20, 10, 5, 0.05) 0%,
					rgba(20, 10, 5, 0.1) 35%,
					rgba(20, 10, 5, 0.65) 60%,
					rgba(20, 10, 5, 0.90) 100%
				);
				display: flex;
				flex-direction: column;
				justify-content: flex-end;
				padding: 0;
			}

			.article-hero-content {
				max-width: 760px;
				margin: 0 auto;
				width: 100%;
				padding: 0 1.75em 2.5em;
			}

			.article-hero-badge {
				display: inline-block;
				font-family: 'Cinzel', serif;
				font-size: 0.62em;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				padding: 0.3em 0.8em;
				border-radius: 3px;
				border: 1px solid rgba(255,255,255,0.35);
				color: rgba(255,255,255,0.85);
				margin-bottom: 0.85em;
			}

			.article-hero h1 {
				font-family: 'Crimson Text', serif;
				font-size: 2.8em;
				font-weight: 400;
				color: #FDFAF4;
				line-height: 1.15;
				margin-bottom: 0.55em;
				text-shadow: 0 2px 12px rgba(0,0,0,0.4);
			}

			.article-hero-desc {
				font-family: 'Crimson Text', serif;
				font-size: 1.1em;
				color: rgba(253, 250, 244, 0.78);
				line-height: 1.55;
				margin-bottom: 1.1em;
				font-style: italic;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.article-hero-meta {
				display: flex;
				align-items: center;
				gap: 1.25em;
				flex-wrap: wrap;
			}

			.article-meta-item {
				font-family: 'Cinzel', serif;
				font-size: 0.68em;
				letter-spacing: 0.1em;
				color: rgba(255, 255, 255, 0.6);
				display: flex;
				align-items: center;
				gap: 0.4em;
			}

			.article-meta-sep {
				color: rgba(255, 255, 255, 0.3);
				font-size: 0.8em;
			}

			/* ——— Article 2-col layout ——— */
			.article-layout {
				display: grid;
				grid-template-columns: 1fr 280px;
				gap: 3em;
				max-width: 1040px;
				margin: 0 auto;
				padding: 0 1.5em;
				padding-top: 0;
				align-items: start;
			}

			.article-body { min-width: 0; }

			/* ——— Article body ——— */
			.prose {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 2.5em 0 3.5em;
				color: var(--text, #2C1F0E);
			}

			/* ——— Sidebar ——— */
			.article-sidebar { padding-top: 2em; }

			.sidebar-block {
				background: #F5EFE0;
				border: 1px solid rgba(184,149,42,0.18);
				border-radius: 6px;
				padding: 1.25em;
				margin-bottom: 1.5em;
			}

			.sidebar-heading {
				font-family: 'Cinzel', serif;
				font-size: 0.68em;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: #A89060;
				margin: 0 0 1em;
			}

			.sidebar-post {
				display: flex;
				flex-direction: column;
				gap: 0.25em;
				padding: 0.75em 0;
				border-top: 1px solid rgba(184,149,42,0.12);
				text-decoration: none;
				color: inherit;
			}
			.sidebar-post:first-of-type { border-top: none; padding-top: 0; }
			.sidebar-post:hover .sidebar-post-title { color: #8B6914; }

			.sidebar-post-title { font-family: 'Crimson Text', serif; font-size: 0.95em; font-weight: 600; color: #2C1F0E; line-height: 1.35; }

			.sidebar-post-desc {
				font-size: 0.78em;
				color: #7A6840;
				line-height: 1.45;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			.sidebar-cta-label { display: block; font-family: 'Cinzel', serif; font-size: 0.65em; letter-spacing: 0.18em; text-transform: uppercase; color: #A89060; margin-bottom: 0.6em; }

			.sidebar-cta-block p { font-size: 0.85em; color: #5A4830; line-height: 1.6; margin-bottom: 1em; }

			.sidebar-cta-btn {
				display: block;
				font-family: 'Cinzel', serif;
				font-size: 0.68em;
				letter-spacing: 0.1em;
				color: #B8952A;
				text-decoration: none;
				border: 1px solid rgba(184,149,42,0.4);
				border-radius: 4px;
				padding: 0.65em 1em;
				text-align: center;
				transition: background 0.2s, color 0.2s;
			}
			.sidebar-cta-btn:hover { background: #B8952A; color: #FDFAF4; }

			.prose :global(h2) {
				font-family: 'Cinzel', serif;
				font-size: 1.15em;
				font-weight: 400;
				color: #2C1F0E;
				margin: 2em 0 0.75em;
				letter-spacing: 0.03em;
			}

			.prose :global(h3) {
				font-family: 'Cinzel', serif;
				font-size: 0.95em;
				font-weight: 500;
				color: #4A3820;
				margin: 1.5em 0 0.5em;
				letter-spacing: 0.04em;
			}

			.prose :global(p) {
				font-size: 1.08em;
				line-height: 1.75;
				color: #3A2A10;
				margin-bottom: 1.25em;
			}

			.prose :global(strong) {
				color: #2C1F0E;
				font-weight: 600;
			}

			.prose :global(blockquote) {
				border-left: 3px solid rgba(184, 149, 42, 0.4);
				margin: 1.5em 0;
				padding: 0.75em 1.25em;
				background: #F5EFE0;
				border-radius: 0 5px 5px 0;
				font-style: italic;
				color: #5A4830;
			}

			.prose :global(ul), .prose :global(ol) {
				padding-left: 1.5em;
				margin-bottom: 1.25em;
			}

			.prose :global(li) {
				margin-bottom: 0.4em;
				line-height: 1.7;
				font-size: 1.05em;
				color: #3A2A10;
			}

			/* ——— Author card ——— */
			.author-card {
				margin-top: 3.5em;
				padding: 1.25em 1.5em;
				border-left: 3px solid rgba(184, 149, 42, 0.35);
				background: #F5EFE0;
				border-radius: 0 5px 5px 0;
			}

			.author-label {
				display: block;
				font-family: 'Cinzel', serif;
				font-size: 0.68em;
				letter-spacing: 0.15em;
				text-transform: uppercase;
				color: #A89060;
				margin-bottom: 0.6em;
			}

			.author-card p {
				font-size: 0.9em;
				color: #7A6840;
				line-height: 1.65;
				margin: 0;
			}

			.author-card a {
				color: #8B6914;
				text-decoration: none;
			}

			.author-card a:hover { text-decoration: underline; }

			/* ——— Related posts ——— */
			.related-posts {
				max-width: 760px;
				margin: 0 auto 3em;
				padding: 0 1em;
				border-top: 1px solid var(--border, rgba(184,149,42,0.22));
				padding-top: 2.5em;
			}

			.related-header {
				display: flex;
				align-items: center;
				gap: 0.75em;
				margin-bottom: 1.5em;
			}

			.related-ornament {
				color: var(--accent, #B8952A);
				font-size: 0.75em;
			}

			.related-title {
				font-family: 'Cinzel', serif;
				font-size: 0.75em;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: var(--text-muted, #7A6840);
				margin: 0;
			}

			.related-grid {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
				gap: 1em;
			}

			.related-card {
				background: var(--bg-secondary, #F5EFE0);
				border: 1px solid var(--border, rgba(184,149,42,0.22));
				border-radius: 6px;
				padding: 1.25em 1.25em 1em;
				transition: border-color 0.2s, background 0.2s;
			}

			.related-card:hover {
				border-color: var(--accent, #B8952A);
				background: var(--bg-card, #FAF6ED);
			}

			.related-link {
				display: flex;
				flex-direction: column;
				gap: 0.4em;
				text-decoration: none;
				color: inherit;
			}

			.related-card-title {
				font-family: 'Crimson Text', serif;
				font-size: 1.05em;
				font-weight: 600;
				color: var(--text, #2C1F0E);
				line-height: 1.35;
			}

			.related-card-desc {
				font-size: 0.82em;
				color: var(--text-muted, #7A6840);
				line-height: 1.45;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			@media (max-width: 900px) {
				.article-layout {
					grid-template-columns: 1fr;
					padding: 0 1em;
				}
				.article-sidebar { padding-top: 0; }
			}

			@media (max-width: 600px) {
				.article-hero { height: 380px; }
				.article-hero h1 { font-size: 2em; }
				.article-hero-desc { display: none; }
			}
		</style>
	</head>

	<body>
		<Header />
		<SearchModal />
		<!-- Hero fuera de <main> para ser full-width sin restricción de 760px -->
		<div class="article-hero">
			<Image
				width={1200}
				height={480}
				src={displayImage}
				alt={title}
				class="article-hero-img"
			/>
			<div class="article-hero-overlay">
				<div class="article-hero-content">
					{cat && (
						<span class="article-hero-badge" style={`border-color:${cat.color}80; color:${cat.color}; background:${cat.color}22`}>
							{cat.label}
						</span>
					)}
					<h1>{title}</h1>
					{description && <p class="article-hero-desc">{description}</p>}
					<div class="article-hero-meta">
						<span class="article-meta-item">
							<FormattedDate date={pubDate} />
						</span>
						{readingTime && (
							<>
								<span class="article-meta-sep">·</span>
								<span class="article-meta-item">{readingTime} min de lectura</span>
							</>
						)}
						{updatedDate && (
							<>
								<span class="article-meta-sep">·</span>
								<span class="article-meta-item">Actualizado: <FormattedDate date={updatedDate} /></span>
							</>
						)}
					</div>
				</div>
			</div>
		</div>
		<main class="article-layout">
			<article class="article-body">
				<div class="prose">
					<slot />
					<div class="author-card">
						<span class="author-label">¿Quieres explorar este proceso?</span>
						<p>
							Puedes trabajar personalmente la regresión con un terapeuta certificado.
							Conoce el trabajo de <a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener">Juan Pablo Loaiza</a>,
							especialista en RVP.
						</p>
					</div>
				</div>
			</article>

			<aside class="article-sidebar">
				{relatedPosts && relatedPosts.length > 0 && (
					<div class="sidebar-block">
						<h2 class="sidebar-heading">Artículos relacionados</h2>
						<nav>
							{relatedPosts.map(p => (
								<a href={`/blog/${p.id}/`} class="sidebar-post">
									<span class="sidebar-post-title">{p.data.title}</span>
									{p.data.description && (
										<span class="sidebar-post-desc">{p.data.description}</span>
									)}
								</a>
							))}
						</nav>
					</div>
				)}
				<div class="sidebar-block sidebar-cta-block">
					<span class="sidebar-cta-label">Trabajo personal</span>
					<p>Sesiones de regresión con un terapeuta certificado en RVP.</p>
					<a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener" class="sidebar-cta-btn">
						juanpabloloaiza.com →
					</a>
				</div>
			</aside>
		</main>
		<Footer />
	</body>
</html>
