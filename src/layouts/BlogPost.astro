---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import SearchModal from '../components/SearchModal.astro';
import { CATEGORY } from '../consts';

import imgVelasSeance    from '../assets/blog/srt-velas-seance.jpg';
import imgVelaOscuridad  from '../assets/blog/srt-vela-oscuridad.jpg';
import imgManosLuz       from '../assets/blog/srt-manos-luz.jpg';
import imgOjoMistico     from '../assets/blog/hipnosis-ojo-mistico.jpg';
import imgMeditacion     from '../assets/blog/rvp-meditacion.jpg';
import imgDefault        from '../assets/blog/hero-meditacion-amanecer.jpg';

import type { ImageMetadata } from 'astro';

const CATEGORY_IMG: Record<string, ImageMetadata> = {
  'carl-wickland':  imgVelasSeance,
  'william-baldwin': imgManosLuz,
  'edith-fiore':    imgMeditacion,
  'alan-sanderson': imgMeditacion,
  'srt':            imgVelaOscuridad,
  'hipnosis':       imgOjoMistico,
};

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, expositor } = Astro.props;
const displayImage = heroImage ?? (expositor ? CATEGORY_IMG[expositor] : undefined) ?? imgDefault;
const cat = expositor ? CATEGORY[expositor] : undefined;

const siteUrl = Astro.site ?? 'https://www.regresionvidaspasadas.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const ogImage = new URL(displayImage.src, siteUrl);

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
  image: ogImage.href,
  url: canonicalUrl.href,
  author: {
    '@type': 'Person',
    name: 'Juan Pablo Loaiza',
    url: 'https://www.juanpabloloaiza.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Regresión a Vidas Pasadas',
    url: siteUrl.toString(),
  },
});
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} image={displayImage} />
		<script type="application/ld+json" set:html={jsonLd}></script>
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
				max-height: 380px;
				overflow: hidden;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: 380px;
				object-fit: cover;
				border-radius: 0;
				margin: 0;
				filter: sepia(15%) brightness(1.02);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em 3em;
				color: var(--text);
			}
			.title {
				text-align: center;
				padding: 2.5em 0 1.5em;
				margin-bottom: 1em;
			}
			.ornament {
				color: #D4AF6A;
				letter-spacing: 0.5em;
				font-size: 0.7em;
				margin-bottom: 1em;
				display: block;
			}
			.title h1 {
				font-size: 2.2em;
				font-weight: 400;
				margin: 0.25em 0 0.5em;
				line-height: 1.2;
				color: #2C1F0E;
			}
			.date {
				font-family: 'Cinzel', serif;
				font-size: 0.72em;
				letter-spacing: 0.12em;
				color: #A89060;
				margin-bottom: 0.5em;
			}
			.post-description {
				font-size: 1.1em;
				color: #7A6840;
				font-style: italic;
				max-width: 560px;
				margin: 0.5em auto 0;
				line-height: 1.65;
			}
			.post-category {
				display: inline-block;
				font-family: 'Cinzel', serif;
				font-size: 0.62em;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				padding: 0.3em 0.8em;
				border-radius: 3px;
				margin-top: 1em;
				border: 1px solid;
			}
			.title-divider {
				width: 60px;
				height: 1px;
				background: linear-gradient(90deg, transparent, #D4AF6A, transparent);
				margin: 2em auto;
			}
			.author-card {
				margin-top: 3em;
				padding: 1.25em 1.5em;
				border-left: 3px solid rgba(184, 149, 42, 0.35);
				background: #F5EFE0;
				border-radius: 0 5px 5px 0;
			}
			.author-label {
				display: block;
				font-family: 'Cinzel', serif;
				font-size: 0.68em;
				letter-spacing: 0.15em;
				text-transform: uppercase;
				color: #A89060;
				margin-bottom: 0.6em;
			}
			.author-card p {
				font-size: 0.9em;
				color: #7A6840;
				line-height: 1.65;
				margin: 0;
			}
			.author-card a {
				color: #8B6914;
				text-decoration: none;
			}
			.author-card a:hover {
				text-decoration: underline;
			}
		</style>
	</head>

	<body>
		<Header />
		<SearchModal />
		<main>
			<article>
				<div class="hero-image">
					<Image width={1200} height={380} src={displayImage} alt={title} />
				</div>
				<div class="prose">
					<div class="title">
						<span class="ornament">✦</span>
						<div class="date">
							<FormattedDate date={pubDate} />
							{updatedDate && <span> · Actualizado: <FormattedDate date={updatedDate} /></span>}
						</div>
						<h1>{title}</h1>
						{cat && (
							<span class="post-category" style={`color:${cat.color}; border-color:${cat.color}40; background:${cat.color}12`}>
								{cat.label}
							</span>
						)}
						{description && <p class="post-description">{description}</p>}
						<div class="title-divider"></div>
					</div>
					<slot />
					<div class="author-card">
						<span class="author-label">Sobre el autor</span>
						<p><a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener">Juan Pablo Loaiza</a> es terapeuta de Regresión a Vidas Pasadas. Si quieres explorar este proceso, puedes conocer su trabajo en <a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener">juanpabloloaiza.com</a>.</p>
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
