---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import SearchModal from '../components/SearchModal.astro';
import { CATEGORY, SLUG_IMG } from '../consts';

import imgVelasSeance    from '../assets/blog/srt-velas-seance.jpg';
import imgVelaOscuridad  from '../assets/blog/srt-vela-oscuridad.jpg';
import imgManosLuz       from '../assets/blog/srt-manos-luz.jpg';
import imgOjoMistico     from '../assets/blog/hipnosis-ojo-mistico.jpg';
import imgMeditacion     from '../assets/blog/rvp-meditacion.jpg';
import imgDefault        from '../assets/blog/hero-meditacion-amanecer.jpg';
import imgCosmos         from '../assets/blog/cosmos-estrellas.jpg';
import imgHumoOscuro     from '../assets/blog/srt-humo-oscuro.jpg';
import imgTerapia        from '../assets/blog/terapia-sesion.jpg';
import imgPortalLuz      from '../assets/blog/portal-luz.jpg';
import imgNinos          from '../assets/blog/ninos-naturaleza.jpg';
import imgMeditGrupal    from '../assets/blog/meditacion-grupal.jpg';
import imgRitualFuego    from '../assets/blog/ritual-fuego.jpg';
import imgSilueta        from '../assets/blog/silueta-espiritual.jpg';
import imgLibros         from '../assets/blog/libros-vintage.jpg';
import imgQueEs          from '../assets/blog/que-es-regresion.jpg';
import imgBeneficios     from '../assets/blog/beneficios-regresion.jpg';
import imgSesion         from '../assets/blog/sesion-regresion.jpg';

import type { ImageMetadata } from 'astro';

const IMG_REGISTRY: Record<string, ImageMetadata> = {
  'srt-velas-seance':    imgVelasSeance,
  'srt-vela-oscuridad':  imgVelaOscuridad,
  'srt-manos-luz':       imgManosLuz,
  'hipnosis-ojo-mistico': imgOjoMistico,
  'rvp-meditacion':      imgMeditacion,
  'hero-meditacion-amanecer': imgDefault,
  'cosmos-estrellas':    imgCosmos,
  'srt-humo-oscuro':     imgHumoOscuro,
  'terapia-sesion':      imgTerapia,
  'portal-luz':          imgPortalLuz,
  'ninos-naturaleza':    imgNinos,
  'meditacion-grupal':   imgMeditGrupal,
  'ritual-fuego':        imgRitualFuego,
  'silueta-espiritual':  imgSilueta,
  'libros-vintage':      imgLibros,
  'que-es-regresion':    imgQueEs,
  'beneficios-regresion': imgBeneficios,
  'sesion-regresion':    imgSesion,
};

const EXPOSITOR_IMG: Record<string, ImageMetadata> = {
  'carl-wickland':   imgVelasSeance,
  'william-baldwin': imgManosLuz,
  'edith-fiore':     imgMeditacion,
  'alan-sanderson':  imgMeditacion,
  'srt':             imgVelaOscuridad,
  'hipnosis':        imgOjoMistico,
};

interface Props extends CollectionEntry<'blog'>['data'] {
  readingTime?: number;
  postId?: string;
  relatedPosts?: CollectionEntry<'blog'>[];
}

const { title, description, pubDate, updatedDate, heroImage, expositor, readingTime, postId, relatedPosts } = Astro.props;

function resolveImage(): ImageMetadata {
  if (heroImage) return heroImage;
  if (postId && SLUG_IMG[postId]) {
    const key = SLUG_IMG[postId];
    if (IMG_REGISTRY[key]) return IMG_REGISTRY[key];
  }
  if (expositor && EXPOSITOR_IMG[expositor]) return EXPOSITOR_IMG[expositor];
  return imgDefault;
}

const displayImage = resolveImage();
const cat = expositor ? CATEGORY[expositor] : undefined;

const siteUrl = Astro.site ?? 'https://www.regresionvidaspasadas.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const ogImage = new URL(displayImage.src, siteUrl);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${canonicalUrl.href}#article`,
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
  image: ogImage.href,
  url: canonicalUrl.href,
  inLanguage: 'es',
  ...(readingTime ? { wordCount: readingTime * 200 } : {}),
  author: {
    '@type': 'Person',
    '@id': 'https://www.juanpabloloaiza.com/#person',
    name: 'Juan Pablo Loaiza',
    url: 'https://www.juanpabloloaiza.com',
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${siteUrl}/#organization`,
    name: 'Regresión a Vidas Pasadas',
    url: siteUrl.toString(),
  },
  isPartOf: { '@id': `${siteUrl}/#organization` },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: siteUrl.toString() },
    { '@type': 'ListItem', position: 2, name: 'Artículos', item: `${siteUrl}/blog/` },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl.href },
  ],
};

const medicalWebPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalWebPage',
  '@id': `${canonicalUrl.href}#medicalpage`,
  name: title,
  url: canonicalUrl.href,
  description,
  inLanguage: 'es',
  medicalAudience: [
    { '@type': 'MedicalAudience', audienceType: 'Patient' },
    { '@type': 'MedicalAudience', audienceType: 'Caregiver' },
  ],
  about: {
    '@type': 'MedicalTherapy',
    name: 'Regresión a Vidas Pasadas',
    alternateName: ['RVP', 'Past Life Regression', 'Terapia de Regresión'],
  },
  author: { '@id': 'https://www.juanpabloloaiza.com/#person' },
  publisher: { '@id': `${siteUrl}/#organization` },
};

const jsonLd = JSON.stringify([articleSchema, breadcrumbSchema, medicalWebPageSchema]);
---

<html lang="es">
  <head>
    <BaseHead title={title} description={description} image={displayImage} ogType="article" />
    <script type="application/ld+json" set:html={jsonLd}></script>
    <style>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        font-family: 'Material Symbols Outlined';
        line-height: 1;
        display: inline-block;
        vertical-align: middle;
      }

      /* ——— Centered article header ——— */
      .article-header {
        padding: 4em 2em 3em;
        text-align: center;
        max-width: 860px;
        margin: 0 auto;
      }

      .article-header-badge {
        display: inline-block;
        padding: 0.35em 1.2em;
        border: 1px solid rgba(184,149,42,0.3);
        border-radius: 100px;
        font-family: 'Libre Caslon Text', serif;
        font-size: 0.5em;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #B8952A;
        background: rgba(184,149,42,0.05);
        margin-bottom: 1.5em;
      }

      .article-header h1 {
        font-family: 'Playfair Display', serif;
        font-size: clamp(1.8em, 5vw, 3.2em);
        font-weight: 900;
        color: #2C1F0E;
        line-height: 1.1;
        margin: 0 0 0.75em;
        letter-spacing: -0.01em;
      }

      .article-header-desc {
        font-family: 'EB Garamond', serif;
        font-size: 1.1em;
        font-style: italic;
        color: #7A6840;
        line-height: 1.65;
        max-width: 560px;
        margin: 0 auto 1.5em;
      }

      .article-header-meta {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75em;
        flex-wrap: wrap;
      }

      .article-meta-by {
        font-family: 'Libre Caslon Text', serif;
        font-size: 0.55em;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #2C1F0E;
      }

      .article-meta-author {
        font-family: 'Libre Caslon Text', serif;
        font-size: 0.55em;
        letter-spacing: 0.12em;
        font-weight: 700;
        color: #2C1F0E;
        border-bottom: 1px solid #B8952A;
        padding-bottom: 0.05em;
      }

      .article-meta-dot { color: #B8952A; font-size: 0.8em; }

      .article-meta-date {
        font-family: 'Libre Caslon Text', serif;
        font-size: 0.55em;
        letter-spacing: 0.1em;
        color: #7A6840;
        text-transform: uppercase;
      }

      /* ——— Hero image (full width) ——— */
      .article-hero-img-wrap {
        width: 100%;
        max-width: 1100px;
        margin: 0 auto 4em;
        height: 480px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 8px 40px rgba(44,31,14,0.15);
      }

      .article-hero-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.7s ease;
        max-width: none;
        border-radius: 0;
      }
      .article-hero-img-wrap:hover .article-hero-img { transform: scale(1.03); }

      .article-hero-gradient {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(44,31,14,0.3) 0%, transparent 50%);
      }

      /* ——— 12-col article grid ——— */
      .article-grid {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 4em;
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 2em 5em;
        align-items: start;
      }

      /* ——— Sticky left sidebar ——— */
      .article-sidebar {
        position: sticky;
        top: 5em;
        display: flex;
        flex-direction: column;
        gap: 2.5em;
      }

      /* TOC */
      .sidebar-toc {
        border-left: 1px solid rgba(184,149,42,0.25);
        padding-left: 1.5em;
      }

      .sidebar-toc-title {
        font-family: 'Public Sans', sans-serif;
        font-size: 0.52em;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: #B8952A;
        margin: 0 0 1.25em;
        font-weight: 700;
      }

      .sidebar-toc-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.75em;
      }

      .sidebar-toc-link {
        font-family: 'EB Garamond', serif;
        font-size: 1em;
        color: #2C1F0E;
        text-decoration: none;
        line-height: 1.3;
        transition: color 0.2s;
        display: block;
      }
      .sidebar-toc-link:hover { color: #B8952A; text-decoration: none; }
      .sidebar-toc-link.active { color: #B8952A; }

      /* Related articles sidebar block */
      .sidebar-related {
        background: #F5EFE0;
        padding: 1.75em;
      }

      .sidebar-related-title {
        font-family: 'Public Sans', sans-serif;
        font-size: 0.5em;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: #B8952A;
        margin: 0 0 1.5em;
        font-weight: 700;
      }

      .sidebar-related-list {
        display: flex;
        flex-direction: column;
        gap: 1.5em;
      }

      .sidebar-related-item { text-decoration: none; color: inherit; display: block; }

      .sidebar-related-cat {
        font-family: 'Libre Caslon Text', serif;
        font-size: 0.45em;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #B8952A;
        display: block;
        margin-bottom: 0.3em;
      }

      .sidebar-related-item-title {
        font-family: 'Playfair Display', serif;
        font-size: 0.9em;
        font-weight: 700;
        color: #2C1F0E;
        line-height: 1.25;
        transition: color 0.2s;
      }
      .sidebar-related-item:hover .sidebar-related-item-title { color: #B8952A; }

      /* Newsletter mini */
      .sidebar-newsletter-mini {
        border: 1px solid rgba(184,149,42,0.2);
        padding: 1.75em;
        text-align: center;
      }

      .sidebar-newsletter-mini .mat-icon { font-size: 1.8em; color: #B8952A; display: block; margin-bottom: 0.75em; }

      .sidebar-newsletter-mini-title {
        font-family: 'Playfair Display', serif;
        font-size: 1em;
        font-weight: 700;
        margin: 0 0 0.75em;
      }

      .sidebar-newsletter-mini-desc {
        font-family: 'EB Garamond', serif;
        font-size: 0.82em;
        font-style: italic;
        color: #7A6840;
        line-height: 1.55;
        margin-bottom: 1.25em;
      }

      .sidebar-newsletter-mini input {
        width: 100%;
        box-sizing: border-box;
        background: rgba(255,255,255,0.5);
        border: 1px solid rgba(184,149,42,0.15);
        padding: 0.6em 1em;
        font-family: 'EB Garamond', serif;
        font-size: 0.9em;
        margin-bottom: 0.5em;
        outline: none;
      }
      .sidebar-newsletter-mini input:focus { border-color: #B8952A; }

      .sidebar-newsletter-mini button {
        width: 100%;
        padding: 0.75em;
        background: #2C1F0E;
        color: #FDFAF4;
        border: none;
        cursor: pointer;
        font-family: 'Libre Caslon Text', serif;
        font-size: 0.48em;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        transition: background 0.2s;
      }
      .sidebar-newsletter-mini button:hover { background: #B8952A; }

      /* ——— Article body ——— */
      .article-body { min-width: 0; }

      .prose {
        font-family: 'EB Garamond', serif;
        font-size: 1.15em;
        line-height: 1.8;
        color: #2C1F0E;
        max-width: 680px;
      }

      /* Drop cap on first paragraph */
      .prose :global(p:first-of-type)::first-letter {
        float: left;
        font-family: 'Playfair Display', serif;
        font-size: 4.5em;
        line-height: 0.8;
        padding: 0.1em 0.4em 0 0;
        color: #B8952A;
        font-weight: 900;
      }

      .prose :global(h2) {
        font-family: 'Playfair Display', serif;
        font-size: 1.5em;
        font-weight: 700;
        color: #2C1F0E;
        margin: 2.5em 0 0.75em;
        line-height: 1.2;
      }

      .prose :global(h3) {
        font-family: 'Playfair Display', serif;
        font-size: 1.2em;
        font-weight: 700;
        color: #3A2A10;
        margin: 2em 0 0.6em;
      }

      .prose :global(p) {
        margin-bottom: 1.4em;
        line-height: 1.8;
      }

      .prose :global(strong) {
        color: #2C1F0E;
        font-weight: 600;
      }

      .prose :global(blockquote) {
        border-left: 4px solid #B8952A;
        margin: 2em 0;
        padding: 1.25em 2em;
        background: rgba(245,239,224,0.4);
        font-style: italic;
        color: #2C1F0E;
      }

      .prose :global(blockquote p) {
        font-family: 'Playfair Display', serif;
        font-size: 1.2em;
        line-height: 1.55;
        margin: 0;
      }

      .prose :global(ul), .prose :global(ol) {
        padding-left: 1.5em;
        margin-bottom: 1.4em;
      }

      .prose :global(li) {
        margin-bottom: 0.5em;
        line-height: 1.7;
      }

      .prose :global(img) {
        width: 100%;
        height: auto;
        margin: 2em 0;
        box-shadow: 0 4px 20px rgba(44,31,14,0.1);
      }

      /* ——— Ornamental divider ——— */
      .ornament {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1em;
        margin: 3em 0;
      }
      .ornament::before, .ornament::after {
        content: "";
        height: 1px;
        flex-grow: 1;
        background: linear-gradient(to right, transparent, #B8952A, transparent);
      }
      .ornament span { color: #B8952A; font-size: 1em; }

      /* ——— Share actions ——— */
      .share-bar {
        display: flex;
        align-items: center;
        gap: 1.5em;
        padding-top: 2.5em;
        border-top: 1px solid rgba(184,149,42,0.12);
        margin-top: 2.5em;
      }

      .share-bar-label {
        font-family: 'Public Sans', sans-serif;
        font-size: 0.52em;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #7A6840;
      }

      .share-btns { display: flex; gap: 0.75em; }

      .share-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 1px solid rgba(184,149,42,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        background: none;
        cursor: pointer;
        color: #7A6840;
        font-size: 1.1em;
        transition: background 0.2s, color 0.2s;
        text-decoration: none;
      }
      .share-btn:hover {
        background: #B8952A;
        color: #FDFAF4;
        border-color: #B8952A;
        text-decoration: none;
      }

      /* ——— Author CTA ——— */
      .author-cta {
        margin-top: 3em;
        padding: 1.5em 1.75em;
        background: #F5EFE0;
        border-left: 3px solid rgba(184,149,42,0.35);
      }

      .author-cta-label {
        display: block;
        font-family: 'Public Sans', sans-serif;
        font-size: 0.52em;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #A89060;
        margin-bottom: 0.6em;
        font-weight: 700;
      }

      .author-cta p {
        font-family: 'EB Garamond', serif;
        font-size: 0.9em;
        color: #7A6840;
        line-height: 1.65;
        margin: 0;
      }

      .author-cta a { color: #8B6914; text-decoration: none; }
      .author-cta a:hover { text-decoration: underline; }

      /* ——— Responsive ——— */
      @media (max-width: 900px) {
        .article-grid {
          grid-template-columns: 1fr;
          padding: 0 1.25em 4em;
          gap: 2.5em;
        }
        .article-sidebar {
          position: static;
          display: grid;
          grid-template-columns: repeat(2, 1fr);
          gap: 1.5em;
        }
        .sidebar-toc { display: none; }
        .article-hero-img-wrap { height: 340px; }
      }

      @media (max-width: 600px) {
        .article-header { padding: 2.5em 1.25em 2em; }
        .article-sidebar { grid-template-columns: 1fr; }
        .article-hero-img-wrap { height: 260px; }
        .prose { font-size: 1em; }
        .prose :global(p:first-of-type)::first-letter { font-size: 3.5em; }
      }
    </style>
  </head>

  <body>
    <Header />
    <SearchModal />

    <!-- Centered article header -->
    <div class="article-header">
      {cat ? (
        <span class="article-header-badge">{cat.label}</span>
      ) : (
        <span class="article-header-badge">Investigación</span>
      )}
      <h1>{title}</h1>
      {description && <p class="article-header-desc">{description}</p>}
      <div class="article-header-meta">
        <span class="article-meta-by">Por</span>
        <span class="article-meta-author">Regresión a Vidas Pasadas</span>
        <span class="article-meta-dot">•</span>
        <span class="article-meta-date"><FormattedDate date={pubDate} /></span>
        {readingTime && (
          <>
            <span class="article-meta-dot">•</span>
            <span class="article-meta-date">{readingTime} min</span>
          </>
        )}
      </div>
    </div>

    <!-- Full-width hero image -->
    <div class="article-hero-img-wrap">
      <Image
        width={1100}
        height={480}
        src={displayImage}
        alt={title}
        class="article-hero-img"
      />
      <div class="article-hero-gradient"></div>
    </div>

    <!-- 12-col grid: sidebar left + article body -->
    <div class="article-grid">

      <!-- LEFT SIDEBAR (sticky) -->
      <aside class="article-sidebar">

        <!-- TOC — populated by JS -->
        <div class="sidebar-toc" id="article-toc">
          <h4 class="sidebar-toc-title">Contenido</h4>
          <ul class="sidebar-toc-list" id="toc-list">
            <!-- filled by client JS -->
          </ul>
        </div>

        <!-- Related articles -->
        {relatedPosts && relatedPosts.length > 0 && (
          <div class="sidebar-related">
            <h4 class="sidebar-related-title">Relacionados</h4>
            <div class="sidebar-related-list">
              {relatedPosts.map(p => {
                const relCat = p.data.expositor ? CATEGORY[p.data.expositor] : undefined;
                return (
                  <a href={`/blog/${p.id}/`} class="sidebar-related-item">
                    <span class="sidebar-related-cat">{relCat ? relCat.label : 'Investigación'}</span>
                    <span class="sidebar-related-item-title">{p.data.title}</span>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        <!-- Newsletter mini -->
        <div class="sidebar-newsletter-mini">
          <span class="material-symbols-outlined mat-icon">mail</span>
          <h4 class="sidebar-newsletter-mini-title">Crónica Editorial</h4>
          <p class="sidebar-newsletter-mini-desc">Reflexiones mensuales sobre la evolución del espíritu.</p>
          <form onsubmit="return false;">
            <input type="email" placeholder="Email" />
            <button type="submit">Suscribirse</button>
          </form>
        </div>

      </aside>

      <!-- ARTICLE BODY -->
      <article class="article-body">
        <div class="prose" id="prose-content">
          <slot />
        </div>

        <!-- Ornament divider before CTA -->
        <div class="ornament">
          <span class="material-symbols-outlined" style="font-size:1em">auto_awesome</span>
        </div>

        <!-- Author/CTA -->
        <div class="author-cta">
          <span class="author-cta-label">¿Quieres explorar este proceso?</span>
          <p>
            Puedes trabajar personalmente la regresión con un terapeuta certificado.
            Conoce el trabajo de <a href="https://www.juanpabloloaiza.com" target="_blank" rel="noopener">Juan Pablo Loaiza</a>,
            especialista en RVP.
          </p>
        </div>

        <!-- Share bar -->
        <div class="share-bar">
          <span class="share-bar-label">Compartir:</span>
          <div class="share-btns">
            <a class="share-btn" href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(canonicalUrl.href)}&text=${encodeURIComponent(title)}`} target="_blank" rel="noopener" aria-label="Compartir en Twitter">
              <span class="material-symbols-outlined" style="font-size:1em">share</span>
            </a>
            <button class="share-btn" onclick="navigator.clipboard?.writeText(window.location.href)" aria-label="Copiar enlace">
              <span class="material-symbols-outlined" style="font-size:1em">link</span>
            </button>
            <button class="share-btn" onclick="window.print()" aria-label="Imprimir">
              <span class="material-symbols-outlined" style="font-size:1em">print</span>
            </button>
          </div>
        </div>
      </article>
    </div>

    <Footer />

    <script>
      // Build TOC from article headings
      const tocList = document.getElementById('toc-list');
      const prose = document.getElementById('prose-content');
      if (tocList && prose) {
        const headings = Array.from(prose.querySelectorAll('h2, h3'));
        if (headings.length < 2) {
          const tocEl = document.getElementById('article-toc');
          if (tocEl) tocEl.style.display = 'none';
        } else {
          headings.forEach((h, i) => {
            if (!h.id) h.id = `section-${i}`;
            const li = document.createElement('li');
            const a = document.createElement('a');
            a.href = `#${h.id}`;
            a.textContent = h.textContent ?? '';
            a.className = 'sidebar-toc-link';
            if (h.tagName === 'H3') a.style.paddingLeft = '1em';
            a.addEventListener('click', e => {
              e.preventDefault();
              document.getElementById(h.id)?.scrollIntoView({ behavior: 'smooth' });
            });
            li.appendChild(a);
            tocList.appendChild(li);
          });

          // Active section highlighting
          const observer = new IntersectionObserver(entries => {
            entries.forEach(entry => {
              const link = tocList.querySelector(`[href="#${entry.target.id}"]`);
              if (link) link.classList.toggle('active', entry.isIntersecting);
            });
          }, { rootMargin: '-20% 0% -70% 0%' });

          headings.forEach(h => observer.observe(h));
        }
      }
    </script>
  </body>
</html>
