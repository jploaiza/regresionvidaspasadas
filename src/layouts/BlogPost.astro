---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
				max-height: 380px;
				overflow: hidden;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: 380px;
				object-fit: cover;
				border-radius: 0;
				margin: 0;
				filter: sepia(15%) brightness(1.02);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em 3em;
				color: var(--text);
			}
			.title {
				text-align: center;
				padding: 2.5em 0 1.5em;
				margin-bottom: 1em;
			}
			.ornament {
				color: #D4AF6A;
				letter-spacing: 0.5em;
				font-size: 0.7em;
				margin-bottom: 1em;
				display: block;
			}
			.title h1 {
				font-size: 2.2em;
				font-weight: 400;
				margin: 0.25em 0 0.5em;
				line-height: 1.2;
				color: #2C1F0E;
			}
			.date {
				font-family: 'Cinzel', serif;
				font-size: 0.72em;
				letter-spacing: 0.12em;
				color: #A89060;
				margin-bottom: 0.5em;
			}
			.post-description {
				font-size: 1.1em;
				color: #7A6840;
				font-style: italic;
				max-width: 560px;
				margin: 0.5em auto 0;
				line-height: 1.65;
			}
			.title-divider {
				width: 60px;
				height: 1px;
				background: linear-gradient(90deg, transparent, #D4AF6A, transparent);
				margin: 2em auto;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image width={1200} height={380} src={heroImage} alt={title} />
					</div>
				)}
				<div class="prose">
					<div class="title">
						<span class="ornament">✦</span>
						<div class="date">
							<FormattedDate date={pubDate} />
							{updatedDate && <span> · Actualizado: <FormattedDate date={updatedDate} /></span>}
						</div>
						<h1>{title}</h1>
						{description && <p class="post-description">{description}</p>}
						<div class="title-divider"></div>
					</div>
					<slot />
					<div class="cta-banner">
						<h3>¿Quieres vivir este proceso?</h3>
						<p>Juan Pablo Loaiza acompaña sesiones de Regresión a Vidas Pasadas de forma individual y profunda.</p>
						<a href="https://www.juanpabloloaiza.com/agenda" target="_blank" rel="noopener" class="cta-btn">
							Agenda tu sesión →
						</a>
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
